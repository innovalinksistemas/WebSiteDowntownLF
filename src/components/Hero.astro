---
/**
 * Hero.astro
 * ─────────────────────────────────────────────────────────────
 * PRIORIDAD: Conversión → reservas directas
 * AUDIENCIA:  Turistas internacionales (aventura / naturaleza)
 * MEDIA:      Imagen estática + Ken Burns HOY
 *             Arquitectura lista para video cuando esté disponible
 *
 * Para activar video cuando esté listo:
 *   1. Coloca los archivos en /public/video/hero.mp4 y hero.webm
 *   2. Cambia VIDEO_READY = true
 *   3. El video se carga como segunda capa; la imagen sigue como poster
 * ─────────────────────────────────────────────────────────────
 */

const VIDEO_READY = false; // ← cambiar a true cuando haya video profesional

// Urgencia dinámica — en producción conectar con disponibilidad real
const ROOMS_LEFT = 3;
const CHECKIN_LABEL = "Disponible esta noche";
---

<section
  class="hero relative isolate min-h-screen overflow-hidden"
  aria-label="La Fortuna Downtown Hotel — Hero"
>

  <!-- ═══════════════════════════════════════════════════
       CAPA 1: Imagen de fondo (Ken Burns con GSAP)
       Reemplazar src por imagen real del hotel en WebP
       Usar srcset para responsive (400/800/1600/2400w)
  ═══════════════════════════════════════════════════ -->
  <picture>
    <source
      type="image/webp"
      srcset="
        /images/hero-400.webp   400w,
        /images/hero-800.webp   800w,
        /images/hero-1600.webp 1600w,
        /images/hero-2400.webp 2400w
      "
      sizes="100vw"
    />
    <!-- Fallback JPG / placeholder Unsplash mientras no haya foto propia -->
    <img
      src="https://images.unsplash.com/photo-1589385680218-7e2f8fca0bd3?auto=format&fit=crop&w=2400&q=80"
      alt="Vista del Volcán Arenal al amanecer desde La Fortuna Downtown Hotel, Costa Rica"
      class="hero-bg absolute inset-0 h-full w-full object-cover"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      width="2400"
      height="1600"
    />
  </picture>

  <!-- ═══════════════════════════════════════════════════
       CAPA 2: Video de fondo (se activa con VIDEO_READY)
       Requisitos del video:
         · Duración loop: 20–30 s
         · Resolución: 1920×1080 mínimo
         · Peso máximo: 8 MB (VP9/WebM) + 12 MB (H.264/MP4)
         · Sin audio (muted es obligatorio para autoplay)
         · Evitar texto o elementos UI en el video
  ═══════════════════════════════════════════════════ -->
  {VIDEO_READY && (
    <video
      class="hero-video absolute inset-0 h-full w-full object-cover"
      autoplay
      muted
      loop
      playsinline
      disablepictureinpicture
      preload="none"
      aria-hidden="true"
      poster="https://images.unsplash.com/photo-1589385680218-7e2f8fca0bd3?auto=format&fit=crop&w=2400&q=80"
    >
      <source src="/video/hero.webm" type="video/webm" />
      <source src="/video/hero.mp4"  type="video/mp4" />
    </video>
  )}

  <!-- ═══════════════════════════════════════════════════
       CAPAS DE COMPOSICIÓN
  ═══════════════════════════════════════════════════ -->
  <div class="hero-overlay absolute inset-0" aria-hidden="true"></div>
  <div class="hero-vignette absolute inset-0" aria-hidden="true"></div>
  <div class="hero-grain absolute inset-0" aria-hidden="true"></div>

  <!-- ═══════════════════════════════════════════════════
       CONTENIDO PRINCIPAL
       Jerarquía de neuromarketing:
         1. Kicker   → ancla geográfica concreta (imagen mental)
         2. H1       → nombre de marca + promesa de ubicación
         3. Tagline  → beneficio emocional (no genérico)
         4. Trust    → prueba social + urgencia (FOMO)
         5. CTAs     → primario (reserva) + secundario (explorar)
  ═══════════════════════════════════════════════════ -->
  <div class="relative z-10 mx-auto flex min-h-screen max-w-5xl flex-col justify-center px-6 py-24 text-center sm:px-10">

    <!-- 1. Kicker — imagen mental concreta, NO genérica -->
    <p class="hero-kicker hero-anim mb-4">
      En el corazón de las experiencias
    </p>

    <!-- 2. H1 — marca + propuesta de valor de ubicación -->
    <h1 class="hero-title hero-anim mb-6">
      LA FORTUNA<br />DOWNTOWN
    </h1>

    <!-- 3. Tagline — beneficio emocional específico -->
    <p class="hero-tagline hero-anim mb-8">
      UNA EXPERIENCIA ÚNICA DE HOSPEDAJE EN LA FORTUNA
    </p>

    <!-- 4. Trust bar — prueba social + escasez (FOMO) -->
    <div class="hero-trust hero-anim mb-10" aria-label="Calificaciones y disponibilidad">
      <div class="hero-trust-inner">

        <!-- Rating Booking -->
        <div class="hero-trust-item">
          <span class="hero-trust-score">8.2</span>
          <span class="hero-trust-label">Booking.com</span>
        </div>

        <div class="hero-trust-divider" aria-hidden="true"></div>

        <!-- Rating TripAdvisor -->
        <div class="hero-trust-item">
          <span class="hero-trust-score">★ 4.4</span>
          <span class="hero-trust-label">TripAdvisor</span>
        </div>

        <div class="hero-trust-divider" aria-hidden="true"></div>

        <!-- Urgencia — escasez real -->
        <div class="hero-trust-item">
          <span class="hero-trust-score hero-trust-urgent">
            <span class="hero-urgency-dot" aria-hidden="true"></span>
            {ROOMS_LEFT} habitaciones disponibles
          </span>
          <span class="hero-trust-label">{CHECKIN_LABEL}</span>
        </div>

      </div>
    </div>

    <!-- 5. CTAs — primario directo a reserva, secundario a explorar -->
    <div class="hero-actions hero-anim flex flex-col items-center justify-center gap-3 sm:flex-row">

      <!-- CTA Primario: máxima fricción removida, acción clara -->
      <a
        href="#habitaciones"
        class="hero-btn hero-btn-primary"
        aria-label="Ver habitaciones disponibles y reservar"
      >
        Reserva tu estancia
      </a>

      <!-- CTA Secundario: para usuarios en fase de consideración -->
      <a
        href="#explorar"
        class="hero-btn hero-btn-outline"
        aria-label="Explorar el hotel y sus experiencias"
      >
        Descubre el hotel
      </a>

    </div>

    <!-- Micro-copy de confianza bajo los CTAs (reduce ansiedad de compra) -->
    <p class="hero-microcopy hero-anim mt-4">
      Mejor precio garantizado · Cancelación gratuita · Sin gastos ocultos
    </p>

  </div>

  <!-- ═══════════════════════════════════════════════════
       ESTADO DEL VOLCÁN — prueba social ambiental
       Ancla la experiencia geográfica en tiempo real
       En producción: conectar con API meteorológica o CMS
  ═══════════════════════════════════════════════════ -->
  <div
    class="hero-status hero-anim absolute bottom-8 left-6 z-10 flex items-center gap-3"
    aria-label="Condiciones actuales en La Fortuna"
  >
    <div class="hero-status-line" aria-hidden="true"></div>
    <div>
      <p class="hero-status-label">Arenal Volcano</p>
      <p class="hero-status-value">
        <span class="hero-live-dot" aria-hidden="true"></span>
        <span id="hero-weather-text">· · ·</span>
      </p>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════
       FAB — Contacto / WhatsApp
       Reemplazar href por wa.me/+506XXXXXXXX para WhatsApp
  ═══════════════════════════════════════════════════ -->
  <a
    href="https://wa.me/50685274677"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Contactar al hotel por WhatsApp"
    class="hero-fab hero-anim absolute bottom-8 right-6 z-10 grid h-14 w-14 place-items-center rounded-full"
  >
    <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
    </svg>
    <span class="sr-only">Contactar al hotel por WhatsApp</span>
  </a>

  <!-- Scroll indicator — invita a continuar explorando -->
  <div class="hero-scroll-indicator hero-anim absolute bottom-8 left-1/2 z-10 -translate-x-1/2 hidden flex-col items-center gap-1 sm:flex" aria-hidden="true">
    <span class="hero-scroll-label">Scroll</span>
    <span class="hero-scroll-arrow"></span>
  </div>

</section>


<script>
  import { gsap } from "gsap";

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  /* ─── Animación de entrada ───────────────────────────── */
  if (!reduced) {
    // Estado inicial: todo invisible y desplazado
    gsap.set(".hero-anim", { opacity: 0, y: 28 });

    // Ken Burns mejorado: escala + deriva leve → más cinematográfico
    gsap.to(".hero-bg", {
      scale: 1.08,
      x: "-2%",
      y: "-1%",
      duration: 14,
      ease: "none", // lineal = más cinematográfico para parallax lento
    });

    // Entrada escalonada del contenido
    gsap.to(".hero-anim", {
      opacity: 1,
      y: 0,
      duration: 1.1,
      ease: "power3.out",
      stagger: 0.14,
      delay: 0.15,
    });
  } else {
    // Sin animación: mostrar todo inmediatamente
    gsap.set(".hero-anim", { opacity: 1, y: 0 });
  }

  /* ─── Video: esperar carga antes de mostrar ──────────── */
  const video = document.querySelector<HTMLVideoElement>(".hero-video");
  if (video) {
    // El video arranca con opacidad 0 y se revela suavemente
    // cuando tiene suficientes datos para reproducir sin interrupciones
    video.style.opacity = "0";
    video.addEventListener("canplaythrough", () => {
      gsap.to(video, { opacity: 1, duration: 1.2, ease: "power2.inOut" });
    }, { once: true });

    // Fallback: si después de 4s no cargó, mantener la imagen
    setTimeout(() => {
      if (video.readyState < 3) {
        video.remove(); // imagen de fondo queda visible
      }
    }, 4000);
  }

  /* ─── Clima en tiempo real — Open Meteo, caché 6 h ─── */
  (() => {
    const CACHE_KEY = 'dlf_weather_v1';
    const TTL = 6 * 60 * 60 * 1000;

    const WMO: Record<number, string> = {
      0: 'Cielo despejado', 1: 'Mayormente despejado',
      2: 'Parcialmente nublado', 3: 'Nublado',
      45: 'Niebla', 48: 'Niebla con escarcha',
      51: 'Llovizna leve', 53: 'Llovizna', 55: 'Llovizna intensa',
      61: 'Lluvia leve', 63: 'Lluvia', 65: 'Lluvia intensa',
      80: 'Aguacero leve', 81: 'Aguacero', 82: 'Aguacero intenso',
      95: 'Tormenta', 96: 'Tormenta con granizo', 99: 'Tormenta con granizo',
    };

    async function loadWeather() {
      // Intentar caché primero
      try {
        const raw = localStorage.getItem(CACHE_KEY);
        if (raw) {
          const { ts, hourly } = JSON.parse(raw);
          if (Date.now() - ts < TTL) return hourly;
        }
      } catch { /* localStorage bloqueado */ }

      const res = await fetch(
        'https://api.open-meteo.com/v1/forecast?latitude=10.4709&longitude=-84.6453' +
        '&hourly=temperature_2m,weathercode&past_days=0&forecast_days=1' +
        '&timezone=America%2FCosta_Rica'
      );
      if (!res.ok) throw new Error('weather fetch failed');
      const { hourly } = await res.json();

      try {
        localStorage.setItem(CACHE_KEY, JSON.stringify({ ts: Date.now(), hourly }));
      } catch { /* storage lleno */ }

      return hourly;
    }

    async function updateWeather() {
      const el = document.getElementById('hero-weather-text');
      if (!el) return;
      try {
        const hourly = await loadWeather();
        const now = new Date();
        // Encontrar el índice de la hora actual (formato "YYYY-MM-DDTHH:00")
        const pad = (n: number) => String(n).padStart(2, '0');
        const key = `${now.getFullYear()}-${pad(now.getMonth()+1)}-${pad(now.getDate())}T${pad(now.getHours())}:00`;
        const idx = (hourly.time as string[]).indexOf(key);
        if (idx === -1) return;
        const temp = Math.round((hourly.temperature_2m as number[])[idx]);
        const code = (hourly.weathercode as number[])[idx];
        const desc = WMO[code] ?? 'Condición actual';
        el.textContent = `${desc} · ${temp}°C`;
      } catch {
        // Mantener el texto por defecto si falla
      }
    }

    updateWeather();
  })();

  /* ─── Urgency dot: parpadeo de "en vivo" ────────────── */
  if (!reduced) {
    gsap.to(".hero-urgency-dot, .hero-live-dot", {
      opacity: 0.3,
      duration: 0.9,
      ease: "power1.inOut",
      yoyo: true,
      repeat: -1,
    });
  }

  /* ─── Scroll indicator: bounce suave ────────────────── */
  if (!reduced) {
    gsap.to(".hero-scroll-arrow", {
      y: 5,
      duration: 0.8,
      ease: "power1.inOut",
      yoyo: true,
      repeat: -1,
      delay: 2,
    });
  }
</script>