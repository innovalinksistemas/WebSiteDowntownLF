---
import { useTranslations } from "../i18n/utils";
const t = useTranslations(Astro.currentLocale);
---

<section id="explorar" class="about-us-section">
  <div class="about-us-inner">
    <p class="about-us-kicker">{t("about.kicker")}</p>

    <div class="about-us-title-wrap">
      <span class="about-us-line" aria-hidden="true"></span>
      <h2 class="about-us-title">{t("about.title")}</h2>
      <span class="about-us-line" aria-hidden="true"></span>
    </div>

    <p class="about-us-copy">
      {t("about.copy")}
    </p>

    <div
      class="about-us-ratings"
      aria-label={t("about.ratings.aria")}
    >
      <div class="about-us-ratings-grid">
        <article class="about-us-rating-item">
          <p class="about-us-rating-source">Google</p>
          <p class="about-us-rating-value">4.3<span>/5</span></p>
        </article>

        <article class="about-us-rating-item">
          <p class="about-us-rating-source">TripAdvisor</p>
          <p class="about-us-rating-value">4.4<span>/5</span></p>
        </article>

        <article class="about-us-rating-item">
          <p class="about-us-rating-source">Booking.com</p>
          <p class="about-us-rating-value">8.1<span>/10</span></p>
        </article>

        <article class="about-us-rating-item">
          <p class="about-us-rating-source">Expedia</p>
          <p class="about-us-rating-value">8.8<span>/10</span></p>
        </article>
      </div>
    </div>

    <figure class="about-us-media">
      <div class="responsive-iframe-container">
        <iframe
          src="https://www.youtube.com/embed/c8maA-QJGYc"
          title={t("about.video.title")}
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen></iframe>
      </div>
    </figure>
  </div>
</section>
