---
/**
 * TropicalBanner.astro
 * ─────────────────────────────────────────────────────────────
 * Banner cinematográfico de pantalla completa.
 * Estilo: imagen edge-to-edge + texto derecho + un CTA.
 * Replica el patrón de la imagen de referencia.
 *
 * Reemplazar la imagen de Unsplash por foto real de
 * Tropical Experiences cuando esté disponible.
 * ─────────────────────────────────────────────────────────────
 */
import { useTranslations } from "../i18n/utils";
const t = useTranslations(Astro.currentLocale);
const [titleLine1, titleLine2] = t("tropic.title").split("\n");
---

<section
  id="tours-top"
  class="tropic-section"
  aria-label={t("tropic.aria")}
>
  
  <img
    src="/images/Rafting.jpg"
    alt={t("tropic.img.alt")}
    class="tropic-bg"
    loading="lazy"
    decoding="async"
    width="2400"
    height="1350"
  />

  
  <div class="tropic-overlay" aria-hidden="true"></div>

  
  <div class="tropic-grain" aria-hidden="true"></div>

  
  <div class="tropic-content">
    <div class="tropic-inner">

      
      <p class="tropic-kicker tropic-anim">{t("tropic.kicker")}</p>

      
      <h2 class="tropic-title tropic-anim">
        {titleLine1}<br />{titleLine2}
      </h2>

      
      <span class="tropic-rule tropic-anim" aria-hidden="true"></span>

      
      <p class="tropic-desc tropic-anim">
        {t("tropic.desc")}
      </p>

      
      <a href="https://online.flippingbook.com/view/743187584/4/" target="_blank" rel="noopener noreferrer" class="tropic-cta tropic-anim">
        {t("tropic.cta")}
      </a>

    </div>
  </div>
</section>

<script>
import { gsap } from "gsap";
import { ScrollTrigger } from "gsap/ScrollTrigger";

gsap.registerPlugin(ScrollTrigger);

const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

if (!reduced) {
  /* Estado inicial */
  gsap.set(".tropic-anim", { opacity: 0, x: 32 });

  /* Ken Burns suave en la imagen */
  gsap.to(".tropic-bg", {
    scale: 1.06,
    x: "-1.5%",
    duration: 16,
    ease: "none",
  });

  /* Entrada de contenido al llegar al viewport */
  ScrollTrigger.create({
    trigger: "#tours-top",
    start: "top 75%",
    once: true,
    onEnter: () => {
      gsap.to(".tropic-anim", {
        opacity: 1,
        x: 0,
        duration: 0.85,
        ease: "power3.out",
        stagger: 0.13,
      });
    },
  });

  /* Hover en el CTA */
  const cta = document.querySelector<HTMLElement>(".tropic-cta");
  cta?.addEventListener("mouseenter", () =>
    gsap.to(cta, { x: 4, duration: 0.22, ease: "power2.out" })
  );
  cta?.addEventListener("mouseleave", () =>
    gsap.to(cta, { x: 0, duration: 0.22, ease: "power2.in" })
  );

} else {
  gsap.set(".tropic-anim", { opacity: 1, x: 0 });
}
</script>