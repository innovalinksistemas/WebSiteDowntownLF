---
const amenities = [
	{
		id: "01",
		title: "Parqueo Privado",
		description:
			"Acceso 24/7 con seguridad y espacios amplios para una llegada cómoda y sin preocupaciones."
	},
	{
		id: "02",
		title: "WiFi de Alta Velocidad",
		description:
			"Cobertura estable en todo el hotel para trabajar, compartir momentos o planificar aventuras."
	},
	{
		id: "03",
		title: "Bar & Restaurante",
		description:
			"Sabores locales e internacionales en un ambiente elegante, ideal para cenas y coctelería."
	},
	{
		id: "04",
		title: "Piscina Tropical",
		description:
			"Espacio relajante al aire libre para descansar luego de explorar La Fortuna."
	}
];
---

<section id="bienestar" class="amenities-section">
	<div class="amenities-inner">
		<div class="amenities-head">
			<p class="amenities-kicker">Facilidades Principales</p>
			<h2 class="amenities-title">Amenidades Pensadas para una Estadía Excepcional</h2>
			<p class="amenities-subtitle">En el corazón de las experiencias</p>
		</div>

		<div class="amenities-grid">
			{
				amenities.map((amenity, index) => (
					<article class={`amenity-card ${index % 2 === 1 ? "amenity-card-shift" : ""}`}>
						<p class="amenity-number">{amenity.id}</p>

						<div class="amenity-icon-wrap" aria-hidden="true">
							{
								amenity.id === "01" && (
									<svg viewBox="0 0 24 24" class="amenity-icon">
										<path
											d="M4 16.75V10.9a1.8 1.8 0 0 1 1.8-1.8h12.4a1.8 1.8 0 0 1 1.8 1.8v5.85M6.2 9.1l1.15-2.3A1.9 1.9 0 0 1 9.05 5.75h5.9a1.9 1.9 0 0 1 1.7 1.05l1.15 2.3M7.5 16.75v1.5M16.5 16.75v1.5M7.2 12.95h.01M16.8 12.95h.01"
											fill="none"
											stroke="currentColor"
											stroke-width="1.7"
											stroke-linecap="round"
											stroke-linejoin="round"
										></path>
									</svg>
								)
							}

							{
								amenity.id === "02" && (
									<svg viewBox="0 0 24 24" class="amenity-icon">
										<path
											d="M3.75 9.6a12.6 12.6 0 0 1 16.5 0M6.7 12.55a8.25 8.25 0 0 1 10.6 0M9.55 15.45a4 4 0 0 1 4.9 0M12 18.15h.01"
											fill="none"
											stroke="currentColor"
											stroke-width="1.8"
											stroke-linecap="round"
											stroke-linejoin="round"
										></path>
									</svg>
								)
							}

							{
								amenity.id === "03" && (
									<svg viewBox="0 0 24 24" class="amenity-icon">
										<path
											d="M8 4.5v9.5M6 4.5v6.5a2 2 0 0 0 4 0V4.5M16 4.5v13.5M14.5 8h3a1.5 1.5 0 0 0 0-3h-3"
											fill="none"
											stroke="currentColor"
											stroke-width="1.7"
											stroke-linecap="round"
											stroke-linejoin="round"
										></path>
									</svg>
								)
							}

							{
								amenity.id === "04" && (
									<svg viewBox="0 0 24 24" class="amenity-icon">
										<path
											d="M3.75 16.7c1.6 1.1 3.2 1.1 4.8 0s3.2-1.1 4.8 0 3.2 1.1 4.8 0M6.5 8.9a2.6 2.6 0 0 1 5.2 0v.3h-1.1M12.95 9.2h2.25a2.35 2.35 0 1 1-1.95 3.65M4.1 13.55h14.8"
											fill="none"
											stroke="currentColor"
											stroke-width="1.7"
											stroke-linecap="round"
											stroke-linejoin="round"
										></path>
									</svg>
								)
							}
						</div>

						<h3 class="amenity-title">{amenity.title}</h3>
						<p class="amenity-description">{amenity.description}</p>
					</article>
				))
			}
		</div>
	</div>
</section>
