---
import logoBlanco from "../assets/logoBlancoDowntown.png";

const quickLinks = [
	{ label: "Habitaciones", href: "#habitaciones" },
	{ label: "Experiencias", href: "#experiencias" },
	{ label: "Bienestar", href: "#bienestar" },
	{ label: "Gastronomia", href: "#gastronomia" },
	{ label: "Ofertas", href: "#ofertas" },
	{ label: "Tours", href: "#tours-top" }
];

const legalLinks = [
	{ label: "Politica de privacidad", href: "#contacto" },
	{ label: "Terminos y condiciones", href: "#contacto" },
	{ label: "Contacto", href: "#contacto" }
];
---

<section id="contacto" class="site-footer-section">
	<div class="site-footer-inner">
		<footer class="offers-footer" aria-label="Footer principal">
			<div class="offers-footer-main">
				<div class="offers-footer-subscribe">
					<a href="/" class="offers-footer-logo" aria-label="Inicio La Fortuna Downtown">
						<img src={logoBlanco.src} alt="La Fortuna Downtown" loading="lazy" />
					</a>
					<p class="offers-footer-label">Hotel boutique en el corazon de La Fortuna</p>
					<p class="offers-footer-copy">
						Disfruta una estadia elegante entre aventura, descanso y la energia natural del Arenal.
					</p>
					<form class="offers-footer-form" action="#" method="post">
						<label for="footer-email" class="sr-only">Correo electronico</label>
						<input
							id="footer-email"
							name="email"
							type="email"
							placeholder="Tu correo electronico"
							autocomplete="email"
							required
						/>
						<button type="submit">Suscribirse</button>
					</form>

					<div class="offers-footer-contact-grid">
						<div>
							<p class="offers-footer-label">Reservaciones</p>
							<a href="tel:+50624791111">+506 2479-1111</a>
						</div>
						<div>
							<p class="offers-footer-label">Correo</p>
							<a href="mailto:reservaciones@lafortunadowntown.com"
								>reservaciones@lafortunadowntown.com</a
							>
						</div>
					</div>
				</div>

				<div class="offers-footer-links-wrap">
					<p class="offers-footer-label">Explora</p>
					<ul class="offers-footer-links">
						{
							quickLinks.map((link) => (
								<li>
									<a href={link.href}>{link.label}</a>
								</li>
							))
						}
					</ul>
				</div>

				<div class="offers-footer-social">
					<p class="offers-footer-label">Visitanos</p>
					<p class="offers-footer-social-copy">
						Avenida Central, La Fortuna, San Carlos, Costa Rica.
					</p>
					<p class="offers-footer-label">Redes</p>
					<div class="offers-footer-social-links">
						<a href="#" aria-label="Facebook">f</a>
						<a href="#" aria-label="X">x</a>
						<a href="#" aria-label="Instagram">ig</a>
						<a href="#" aria-label="YouTube">yt</a>
						<a href="#" aria-label="LinkedIn">in</a>
					</div>
				</div>
			</div>

			<div class="offers-footer-bottom">
				<p>&copy; 2026 La Fortuna Downtown. Todos los derechos reservados.</p>
				<ul>
					{
						legalLinks.map((link) => (
							<li>
								<a href={link.href}>{link.label}</a>
							</li>
						))
					}
				</ul>
			</div>
		</footer>
	</div>
</section>
