---
const faqs = [
	{
		id: "q1",
		question: "¿Cuál es el mejor momento para visitar el volcán?",
		answer: "Las vistas más claras típicamente ocurren durante la estación seca de diciembre a abril, aunque las primeras mañanas en la estación verde ofrecen vistas místicas con niebla. Recomendamos visitarlo al amanecer para las mejores temperaturas y visibilidad."
	},
	{
		id: "q2",
		question: "¿Ofrecen transferencias desde el aeropuerto?",
		answer: "Sí, coordinamos traslados privados y compartidos desde los aeropuertos de SJO y LIR directamente a nuestro santuario boutique en el centro de La Fortuna. Contáctanos para reservar tu transferencia."
	},
	{
		id: "q3",
		question: "¿Es segura el agua del grifo para beber?",
		answer: "El agua del grifo en La Fortuna es generalmente segura, pero proporcionamos estaciones de agua filtrada artesanalmente en toda la propiedad para tu conveniencia."
	},
	{
		id: "q4",
		question: "¿Cuál es la política de cancelación?",
		answer: "Las cancelaciones hechas 14 días antes de tu llegada reciben un reembolso completo. Se aplican políticas estacionales especiales durante períodos pico. Contáctanos para políticas específicas según tus fechas."
	},
	{
		id: "q5",
		question: "¿Qué se incluye en el desayuno?",
		answer: "Nuestro desayuno incluye opciones locales e internacionales, con productos frescos de la región. Disponemos de opciones vegetarianas, veganas y sin gluten. Se sirve de 7:00 AM a 10:00 AM en el comedor principal."
	},
	{
		id: "q6",
		question: "¿Tienen estacionamiento disponible?",
		answer: "Sí, ofrecemos estacionamiento seguro para los huéspedes. No hay costo adicional. Nuestro personal puede ayudarte con instrucciones de acceso y ubicación."
	},
	{
		id: "q7",
		question: "¿Dónde puedo encontrar tours y actividades locales?",
		answer: "Nuestro equipo de expertos locales puede ayudarte a planificar tours al Volcán Arenal, Catarata Río Fortuna, aguas termales y otras experiencias. Ofrecemos recomendaciones personalizadas según tus intereses."
	},
	{
		id: "q8",
		question: "¿Es seguro el área de La Fortuna?",
		answer: "Sí, La Fortuna es generalmente segura para turistas. Recomendamos tomar precauciones estándar como en cualquier área turística. Nuestro personal está disponible 24/7 para asistencia si lo necesitas."
	}
];

const structuredData = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": faqs.map(faq => ({
		"@type": "Question",
		"name": faq.question,
		"acceptedAnswer": {
			"@type": "Answer",
			"text": faq.answer
		}
	}))
};
---

<section id="faq" class="faq-section">
	<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

	<div class="faq-inner">
		<p class="faq-kicker">Preguntas Frecuentes</p>

		<div class="faq-title-wrap">
			<span class="faq-line" aria-hidden="true"></span>
			<h2 class="faq-title">Todo lo que debes saber</h2>
			<span class="faq-line" aria-hidden="true"></span>
		</div>

		<p class="faq-description">
			Respuestas a las preguntas más comunes de nuestros huéspedes sobre La Fortuna Downtown
		</p>

		<div class="faq-container" role="region" aria-label="Preguntas frecuentes">
			{
				faqs.map(({ id, question, answer }) => (
					<details class="faq-item" id={id}>
						<summary class="faq-question">
							<span class="faq-question-text">{question}</span>
							<svg
								class="faq-icon"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								aria-hidden="true"
								focusable="false"
							>
								<polyline points="6 9 12 15 18 9"></polyline>
							</svg>
						</summary>
						<div class="faq-answer">
							<p>{answer}</p>
						</div>
					</details>
				))
			}
		</div>
	</div>
</section>

<script>
	// Enhance FAQ interactivity
	document.querySelectorAll(".faq-item").forEach((item) => {
		const summary = item.querySelector(".faq-question");
		if (summary) {
			summary.addEventListener("click", (e) => {
				// Close other open items for a better mobile experience
				if (item.open) {
					document.querySelectorAll(".faq-item[open]").forEach((other) => {
						if (other !== item) {
							other.open = false;
						}
					});
				}
			});
		}
	});

	// Smooth scroll to FAQ when clicking from nav
	const faqLink = document.querySelector('a[href="#faq"]');
	if (faqLink) {
		faqLink.addEventListener("click", (e) => {
			e.preventDefault();
			const faqSection = document.getElementById("faq");
			if (faqSection) {
				faqSection.scrollIntoView({ behavior: "smooth" });
			}
		});
	}
</script>

<style>
	.faq-section {
		position: relative;
		padding: clamp(4.2rem, 9vw, 7.8rem) 1.2rem clamp(4rem, 8vw, 6.4rem);
		background: linear-gradient(180deg, #f0ece6 0%, #ece7de 100%);
		color: #2d2a26;
	}

	.faq-inner {
		max-width: 86rem;
		margin: 0 auto;
		text-align: center;
	}

	.faq-kicker {
		font-family: var(--font-display);
		font-size: clamp(1.2rem, 2.4vw, 1.9rem);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		margin: 0;
		color: #ab8840;
	}

	.faq-title-wrap {
		margin: clamp(1.3rem, 2.4vw, 2.2rem) auto 0;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: clamp(0.8rem, 2vw, 2.2rem);
		max-width: 74rem;
	}

	.faq-line {
		height: 1px;
		background: rgba(45, 42, 38, 0.56);
	}

	.faq-title {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(2rem, 4.6vw, 4rem);
		line-height: 0.96;
		letter-spacing: 0.01em;
		text-wrap: balance;
	}

	.faq-description {
		margin: clamp(1.2rem, 2rem, 2rem) auto 0;
		max-width: 49rem;
		font-size: clamp(0.9rem, 1.15vw, 1.1rem);
		line-height: 1.45;
		color: rgba(45, 42, 38, 0.75);
	}

	.faq-container {
		margin: clamp(2.4rem, 4vw, 3.8rem) auto 0;
		max-width: 54rem;
		display: flex;
		flex-direction: column;
		gap: clamp(0.8rem, 1.4vw, 1.2rem);
	}

	.faq-item {
		background: rgba(255, 255, 255, 0.6);
		border: 1px solid rgba(45, 42, 38, 0.12);
		border-radius: clamp(0.3rem, 0.5vw, 0.5rem);
		overflow: hidden;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		box-shadow: 0 2px 6px rgba(0, 0, 0, 0.04);
	}

	.faq-item:hover {
		border-color: rgba(45, 42, 38, 0.24);
		box-shadow: 0 8px 16px rgba(0, 0, 0, 0.08);
	}

	.faq-item[open] {
		border-color: rgba(171, 136, 64, 0.4);
		background: rgba(255, 255, 255, 0.85);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
	}

	.faq-question {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: clamp(0.8rem, 1.5vw, 1.6rem);
		padding: clamp(1.1rem, 2vw, 1.6rem) clamp(1.2rem, 2vw, 1.8rem);
		cursor: pointer;
		user-select: none;
		list-style: none;
		background: transparent;
		border: none;
		font-family: var(--font-body);
		font-size: clamp(0.95rem, 1.1vw, 1.1rem);
		font-weight: 600;
		letter-spacing: 0.01em;
		color: inherit;
		text-align: left;
		transition: color 0.2s ease;
	}

	.faq-question:hover {
		color: #ab8840;
	}

	.faq-question::-webkit-details-marker {
		display: none;
	}

	.faq-question-text {
		flex: 1;
		line-height: 1.3;
	}

	.faq-icon {
		width: clamp(1.2rem, 1.8vw, 1.5rem);
		height: clamp(1.2rem, 1.8vw, 1.5rem);
		flex-shrink: 0;
		color: #ab8840;
		transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.faq-item[open] .faq-icon {
		transform: rotate(180deg);
	}

	.faq-answer {
		padding: 0 clamp(1.2rem, 2vw, 1.8rem) clamp(1.1rem, 2vw, 1.6rem);
		border-top: 1px solid rgba(45, 42, 38, 0.08);
		animation: slideDown 0.3s cubic-bezier(0.4, 0, 0.2, 1) forwards;
	}

	@keyframes slideDown {
		from {
			opacity: 0;
			transform: translateY(-8px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.faq-answer p {
		margin: 0;
		font-size: clamp(0.9rem, 1vw, 1rem);
		line-height: 1.55;
		color: rgba(45, 42, 38, 0.8);
	}

	/* Accessibility & Reduced Motion */
	@media (prefers-reduced-motion: reduce) {
		.faq-item {
			transition: none;
		}

		.faq-question {
			transition: none;
		}

		.faq-icon {
			transition: none;
		}

		.faq-answer {
			animation: none;
		}
	}

	/* Mobile optimizations */
	@media (max-width: 640px) {
		.faq-title-wrap {
			grid-template-columns: auto;
			gap: clamp(0.4rem, 1.2vw, 0.8rem);
		}

		.faq-line {
			display: none;
		}

		.faq-question {
			padding: clamp(1rem, 1.8vw, 1.4rem) clamp(1rem, 1.6vw, 1.4rem);
		}

		.faq-answer {
			padding: 0 clamp(1rem, 1.6vw, 1.4rem) clamp(1rem, 1.8vw, 1.4rem);
		}
	}
</style>
