---
import logoBlanco from "../assets/logoBlancoDowntown.png";
import logoNegro from "../assets/logonegro.png";
import { useTranslations } from "../i18n/utils";

const t = useTranslations(Astro.currentLocale);

const linksLeft = [
  { label: t("header.nav.rooms"),       href: "#habitaciones" },
  { label: t("header.nav.experiences"), href: "#tours-top" },
  { label: t("header.nav.wellness"),    href: "#bienestar" },
];

const seasonLabel = t("header.nav.season");
const seasonHref  = t("header.nav.season.href");

const linksRight = [
  { label: t("header.nav.gastronomy"), href: "#gastronomia" },
  { label: t("header.nav.gallery"),    href: t("header.nav.gallery.href") },
  { label: t("header.nav.faq"),        href: t("header.nav.faq.href") },
];

const homeHref = t("header.home.href");
const currentLang = Astro.currentLocale ?? "es";
const switchHref = currentLang === "es" ? "/en" : "/";
const switchLabel = t("lang.switch.label");
const switchAria = t("lang.switch.aria");
---

<header class="site-header" data-header>

  <div class="site-header-desktop">

    <nav class="header-links" aria-label="Secciones principales">
      {linksLeft.map((l) => (
        <a href={l.href} class="header-link">{l.label}</a>
      ))}
      <a href={seasonHref} class="header-link header-season" aria-label={seasonLabel}>
        <span class="season-text">{seasonLabel}</span>
        <!-- gotas de lluvia -->
        <span class="season-rain" aria-hidden="true">
          {Array.from({length: 8}).map((_, i) => (
            <span class={`rain-drop rain-drop--${i+1}`}></span>
          ))}
        </span>
      </a>
    </nav>

    <a href={homeHref} class="header-brand" aria-label={t("header.aria.brand")}>
      <img
        src={logoBlanco.src}
        alt="La Fortuna Downtown"
        class="header-logo header-logo--light"
        loading="eager"
        width="160"
        height="64"
      />
      <img
        src={logoNegro.src}
        alt="La Fortuna Downtown"
        class="header-logo header-logo--dark"
        loading="eager"
        width="160"
        height="64"
        aria-hidden="true"
      />
    </a>

    <nav class="header-links header-links--right" aria-label="Contenido adicional">
      {linksRight.map((l) => (
        <a href={l.href} class="header-link">{l.label}</a>
      ))}

      <div class="header-cta-wrap">
        <p class="header-social-proof" aria-label="Calificación 4.9 en Booking">
          <span class="header-star" aria-hidden="true">★</span>
          {t("header.social.proof").replace("★ ", "")}
        </p>
        <a href={t("header.cta.book.href")} class="header-reserve-btn">
          {t("header.cta.book")}
        </a>
        <a href={switchHref} class="header-lang-switch" aria-label={switchAria} title={switchAria}>
          {switchLabel}
        </a>
      </div>
    </nav>

  </div>

  <div class="site-header-mobile">

    <a href={homeHref} class="header-brand" aria-label={t("header.aria.brand")}>
      <img
        src={logoBlanco.src}
        alt="La Fortuna Downtown"
        class="header-logo header-logo--light"
        loading="eager"
        width="120"
        height="48"
      />
      <img
        src={logoNegro.src}
        alt="La Fortuna Downtown"
        class="header-logo header-logo--dark"
        loading="eager"
        width="120"
        height="48"
        aria-hidden="true"
      />
    </a>

    <button
      type="button"
      class="mobile-menu-toggle"
      data-menu-toggle
      aria-expanded="false"
      aria-controls="mobile-navigation"
      aria-label={t("header.aria.open")}
    >
      <span class="toggle-bars" aria-hidden="true">
        <span class="toggle-bar toggle-bar--1"></span>
        <span class="toggle-bar toggle-bar--2"></span>
        <span class="toggle-bar toggle-bar--3"></span>
      </span>
      <span class="sr-only">Menú</span>
    </button>

  </div>

  <nav
    id="mobile-navigation"
    class="site-mobile-menu"
    data-menu-panel
    aria-label="Menú móvil"
    aria-hidden="true"
  >
    <button
      type="button"
      class="site-mobile-close"
      data-menu-close
      aria-label={t("header.aria.close")}
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M1 1L17 17M17 1L1 17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>

    <div class="site-mobile-nav">
      {[...linksLeft].map((l) => (
        <a href={l.href} class="site-mobile-link" data-menu-close>{l.label}</a>
      ))}
      <a href={seasonHref} class="site-mobile-link site-mobile-season" data-menu-close>
        🌿 {seasonLabel}
      </a>
      {[...linksRight].map((l) => (
        <a href={l.href} class="site-mobile-link" data-menu-close>{l.label}</a>
      ))}

      <div class="site-mobile-cta">
        <p class="site-mobile-social-proof">
          <span aria-hidden="true">★</span> {t("header.mobile.social.proof").replace("★ ", "")}
        </p>
        <a
          href={t("header.cta.book.href")}
          class="site-mobile-reserve"
          data-menu-close
        >
          {t("header.cta.book")}
        </a>
        <a href={switchHref} class="site-mobile-lang-switch">
          {switchLabel}
        </a>
      </div>
    </div>
  </nav>

</header>



<script>
(() => {
  /* ─── Referencias ─────────────────────────────────────────── */
  const header = document.querySelector<HTMLElement>("[data-header]");
  if (!header) return;

  const toggle    = header.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const panel     = header.querySelector<HTMLElement>("[data-menu-panel]");
  const closeEls  = header.querySelectorAll<HTMLElement>("[data-menu-close]");

  /* ─── Scroll offset — recalculado solo en resize ───────────── */
  let headerOffsetCache = 0;

  const recalcOffset = () => {
    const bar =
      window.innerWidth >= 1024
        ? header.querySelector<HTMLElement>(".site-header-desktop")
        : header.querySelector<HTMLElement>(".site-header-mobile");
    headerOffsetCache = (bar?.offsetHeight ?? 64) + 18;
  };

  /* ─── Estado visual: transparente ↔ sólido ─────────────────── */
  const forceSolid = document.body.classList.contains("header-solid");
  const updateState = () => {
    const isOpen = header.classList.contains("menu-open");
    const solid  = forceSolid || window.scrollY > 24 || isOpen;
    header.classList.toggle("is-scrolled", solid);
  };

  /* ─── Abrir / cerrar panel móvil ───────────────────────────── */
  const setOpen = (open: boolean) => {
    header.classList.toggle("menu-open", open);
    document.body.classList.toggle("menu-open", open);

    // Visibilidad: clase en lugar de `hidden` → respeta transición CSS
    panel?.classList.toggle("is-visible", open);
    panel?.setAttribute("aria-hidden", String(!open));

    if (toggle) {
      toggle.setAttribute("aria-expanded", String(open));
      toggle.setAttribute(
        "aria-label",
        open ? "Cerrar menú principal" : "Abrir menú principal"
      );
    }

    // Focus trap mínimo: al abrir, foco al primer link del panel
    if (open && panel) {
      const first = panel.querySelector<HTMLElement>("a, button");
      first?.focus();
    }

    updateState();
  };

  /* ─── Focus trap: Tab / Shift+Tab dentro del panel ─────────── */
  panel?.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key !== "Tab") return;
    const focusable = Array.from(
      panel.querySelectorAll<HTMLElement>("a[href], button:not([disabled])")
    );
    if (!focusable.length) return;

    const first = focusable[0];
    const last  = focusable[focusable.length - 1];

    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  });

  // Cerrar con Escape
  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "Escape" && header.classList.contains("menu-open")) {
      setOpen(false);
      toggle?.focus();
    }
  });

  /* ─── Scroll suave con offset ───────────────────────────────── */
  const scrollTo = (id: string): boolean => {
    const target = document.querySelector<HTMLElement>(id);
    if (!target) return false;

    const top     = target.getBoundingClientRect().top + window.scrollY - headerOffsetCache;
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    window.scrollTo({ top: Math.max(top, 0), behavior: reduced ? "auto" : "smooth" });
    window.history.replaceState(null, "", id);
    return true;
  };

  /* ─── Eventos ───────────────────────────────────────────────── */
  toggle?.addEventListener("click", () =>
    setOpen(!header.classList.contains("menu-open"))
  );

  closeEls.forEach((el) => el.addEventListener("click", () => setOpen(false)));

  header.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
    a.addEventListener("click", (e) => {
      const href = a.getAttribute("href");
      if (!href || href === "#") return;
      if (scrollTo(href)) {
        e.preventDefault();
        setOpen(false);
      }
    });
  });

  /* ─── Resize — debounced ────────────────────────────────────── */
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      recalcOffset();
      if (window.innerWidth >= 1024) setOpen(false);
    }, 100);
  });

  /* ─── Init ──────────────────────────────────────────────────── */
  window.addEventListener("scroll", updateState, { passive: true });
  recalcOffset();
  updateState();
})();
</script>

<style>
/* ── TEMPORADA VERDE ───────────────────────────────────────── */
.header-season {
  position: relative;
  overflow: hidden;
  padding: 0.3rem 0.7rem;
  border-radius: 4px;
  letter-spacing: 0.13em;
  white-space: nowrap;
  transition: color 0.3s ease, background 0.3s ease;
}

.header-season:hover {
  color: #a8e6b3 !important;
  background: rgba(42, 90, 50, 0.25);
}

.season-text {
  position: relative;
  z-index: 2;
}

/* Color de hojas según estado del header */
.header-season { color: #e8d5a0; } /* crema dorado — visible sobre fondo oscuro */
.site-header.is-scrolled .header-season { color: rgba(255,255,255,0.95); } /* blanco — visible sobre verde sólido */

/* ── Hojas ── */
.season-flora {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 1;
}

.season-leaf {
  position: absolute;
  bottom: -100%;
  width: 18px;
  opacity: 0;
  transform-origin: bottom center;
  transition: none;
}

.season-leaf--1 { left: 15%; width: 16px; }
.season-leaf--2 { left: 45%; width: 14px; }
.season-leaf--3 { left: 72%; width: 13px; }

.header-season:hover .season-leaf--1 {
  animation: leafRise 0.5s ease-out 0.05s forwards, leafSway 2s ease-in-out 0.55s infinite;
}
.header-season:hover .season-leaf--2 {
  animation: leafRise 0.5s ease-out 0.18s forwards, leafSway 2.2s ease-in-out 0.68s infinite alternate;
}
.header-season:hover .season-leaf--3 {
  animation: leafRise 0.5s ease-out 0.1s forwards, leafSway 1.9s ease-in-out 0.6s infinite alternate-reverse;
}

@keyframes leafRise {
  from { bottom: -100%; opacity: 0; }
  to   { bottom: -2px;  opacity: 1; }
}

@keyframes leafSway {
  0%   { transform: rotate(-6deg); }
  50%  { transform: rotate(6deg);  }
  100% { transform: rotate(-6deg); }
}

/* ── Lluvia ── */
.season-rain {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 1;
}

.rain-drop {
  position: absolute;
  top: -8px;
  width: 1.5px;
  height: 8px;
  border-radius: 2px;
  background: rgba(140, 210, 255, 0.7);
  opacity: 0;
}

/* Posiciones X de cada gota */
.rain-drop--1  { left: 8%;  }
.rain-drop--2  { left: 18%; }
.rain-drop--3  { left: 29%; }
.rain-drop--4  { left: 41%; }
.rain-drop--5  { left: 55%; }
.rain-drop--6  { left: 67%; }
.rain-drop--7  { left: 79%; }
.rain-drop--8  { left: 90%; }

.header-season:hover .rain-drop { animation: rainFall 0.8s linear infinite; }
.header-season:hover .rain-drop--1  { animation-delay: 0s;    }
.header-season:hover .rain-drop--2  { animation-delay: 0.15s; }
.header-season:hover .rain-drop--3  { animation-delay: 0.30s; }
.header-season:hover .rain-drop--4  { animation-delay: 0.05s; }
.header-season:hover .rain-drop--5  { animation-delay: 0.22s; }
.header-season:hover .rain-drop--6  { animation-delay: 0.40s; }
.header-season:hover .rain-drop--7  { animation-delay: 0.12s; }
.header-season:hover .rain-drop--8  { animation-delay: 0.35s; }

@keyframes rainFall {
  0%   { top: -8px;  opacity: 0;   }
  10%  { opacity: 0.8; }
  90%  { opacity: 0.6; }
  100% { top: 110%;  opacity: 0;   }
}

/* ── Móvil ── */
.site-mobile-season {
  color: #6dbf7e !important;
  font-style: normal;
}

.header-lang-switch,
.site-mobile-lang-switch {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: inherit;
  opacity: 0.7;
  text-decoration: none;
  transition: opacity 0.2s;
  padding: 0.25rem 0.5rem;
  border: 1px solid currentColor;
  border-radius: 3px;
}
.header-lang-switch:hover,
.site-mobile-lang-switch:hover {
  opacity: 1;
}
.site-mobile-lang-switch {
  margin-top: 0.5rem;
  display: inline-block;
}
</style>