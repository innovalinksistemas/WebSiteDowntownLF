---
import { useTranslations } from "../i18n/utils";
const t = useTranslations(Astro.currentLocale);

const bookingUrl = "https://www.simplebooking.it/ibe2/hotel/9184/?hid=9184&lang=ES&cur=USD";

const baseTags = [
  t("rooms.tags.base.0"),
  t("rooms.tags.base.1"),
  t("rooms.tags.base.2"),
  t("rooms.tags.base.3"),
  t("rooms.tags.base.4"),
  t("rooms.tags.base.5"),
  t("rooms.tags.base.6"),
];

const rooms = [
  {
    title: t("rooms.room.doble.title"),
    description: t("rooms.room.doble.desc"),
    longDescription: t("rooms.long.desc"),
    size: "22 m²",
    guests: 2,
    beds: t("rooms.room.doble.beds"),
    features: ["ac", "balcony", "pool", "wifi"],
    tags: [...baseTags, t("rooms.tags.stairs")],
    images: [
      "https://i.ibb.co/SwhzWkZR/Estandar-Doble4.png",
      "https://i.ibb.co/PGZPHP1N/Estandar-Doble3.png",
      "https://i.ibb.co/YFLqgW2q/Estandar-Doble2.png",
      "https://i.ibb.co/rRdWHxfw/Estandar-Doble1.png",
    ],
    href: bookingUrl,
  },
  {
    title: t("rooms.room.triple.title"),
    description: t("rooms.room.triple.desc"),
    longDescription: t("rooms.long.desc"),
    size: "26 m²",
    guests: 3,
    beds: t("rooms.room.triple.beds"),
    features: ["ac", "balcony", "pool", "wifi"],
    tags: baseTags,
    images: [
      "https://i.ibb.co/SX2LGSHN/Estandar-Triple3.png",
      "https://i.ibb.co/whNd3XSv/Estandar-Triple2.png",
      "https://i.ibb.co/j90LrhVJ/Estandar-Triple1.png",
      "https://i.ibb.co/pvrBmBw4/Estandar-Triple4.webp",
    ],
    href: bookingUrl,
  },
  {
    title: t("rooms.room.superior.title"),
    description: t("rooms.room.superior.desc"),
    longDescription: t("rooms.long.desc"),
    size: "24 m²",
    guests: 2,
    beds: t("rooms.room.superior.beds"),
    features: ["ac", "balcony", "pool", "wifi"],
    tags: baseTags,
    images: [
      "https://i.ibb.co/kshJL68d/superior3.png",
      "https://i.ibb.co/jPQ5JDvP/superior4.png",
      "https://i.ibb.co/p6DwHt0w/superior2.png",
      "https://i.ibb.co/bj0GzzS3/superior1.png",
    ],
    href: bookingUrl,
  },
  {
    title: t("rooms.room.tropical.title"),
    description: t("rooms.room.tropical.desc"),
    longDescription: t("rooms.long.desc"),
    size: "34 m²",
    guests: 5,
    beds: t("rooms.room.tropical.beds"),
    features: ["ac", "balcony", "pool", "wifi"],
    tags: baseTags,
    images: [
      "https://i.ibb.co/gbVPz97Z/tropical3.png",
      "https://i.ibb.co/YB0G8WF8/tropical4.png",
      "https://i.ibb.co/JF1xgnxG/tropical1.png",
      "https://i.ibb.co/h1p4Cwgh/tropical2.png",
    ],
    href: bookingUrl,
  },
  {
    title: t("rooms.room.confort.title"),
    description: t("rooms.room.confort.desc"),
    longDescription: t("rooms.long.desc"),
    size: "28 m²",
    guests: 2,
    beds: t("rooms.room.confort.beds"),
    features: ["ac", "balcony", "pool", "wifi"],
    tags: baseTags,
    images: [
      "/images/rooms/confort/confort-1.jpg",
      "/images/rooms/confort/confort-2.jpg",
      "/images/rooms/confort/confort-family.jpg",
      "/images/rooms/confort/bano.jpg",
    ],
    href: bookingUrl,
  },
  {
    title: t("rooms.room.confortfam.title"),
    description: t("rooms.room.confortfam.desc"),
    longDescription: t("rooms.long.desc"),
    size: "40 m²",
    guests: 5,
    beds: t("rooms.room.confortfam.beds"),
    features: ["ac", "balcony", "pool", "wifi"],
    tags: baseTags,
    images: [
      "/images/rooms/tropical-family/tf-1.jpg",
      "/images/rooms/tropical-family/tf-2.jpg",
      "/images/rooms/tropical-family/tf-3.jpg",
      "/images/rooms/tropical-family/tf-4.jpg",
    ],
    href: bookingUrl,
  },
];
---

<section id="habitaciones" class="rooms-section">
	<div class="rooms-inner">

		<div class="rooms-header">
			<span class="rooms-line rooms-header-anim" aria-hidden="true"></span>
			<h2 class="rooms-title rooms-header-anim">{t("rooms.section.title")}</h2>
		</div>

		<div class="rooms-grid">
			{rooms.map((room, i) => (
				<article class="room-card" data-room-index={i}>
					<button
						type="button"
						class="room-image-link"
						data-room-modal={i}
						aria-label={`${t("rooms.cta.details")} ${room.title}`}
					>
						<img src={room.images[0]} alt={room.title} loading="lazy" decoding="async" />
					</button>
					<h3 class="room-card-title">{room.title}</h3>
					<p class="room-card-description">{room.description}</p>
					<button type="button" class="room-read-link" data-room-modal={i}>{t("rooms.cta.details")}</button>
					<a
						href={bookingUrl}
						class="room-book-btn"
						target="_blank"
						rel="noopener noreferrer"
						aria-label={`Reservar ${room.title}`}
					>
						{t("rooms.cta.book")}
					</a>
				</article>
			))}
		</div>

	</div>
</section>


<div class="room-modal" id="room-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="room-modal-title">
	<div class="room-modal-backdrop" data-room-close></div>

	<div class="room-modal-dialog">
		
		<div class="room-modal-gallery">
			<button class="room-modal-nav room-modal-prev" id="room-modal-prev" aria-label={t("rooms.modal.prev")} type="button">
				<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M13 16L7 10L13 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
			</button>
			<img class="room-modal-main-img" id="room-modal-main-img" src="" alt="" />
			<button class="room-modal-nav room-modal-next" id="room-modal-next" aria-label={t("rooms.modal.next")} type="button">
				<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M7 16L13 10L7 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
			</button>
			<span class="room-modal-counter" id="room-modal-counter">1 / 4</span>
			<div class="room-modal-thumbs" id="room-modal-thumbs"></div>
		</div>

		
		<div class="room-modal-panel">
			<button class="room-modal-close" data-room-close aria-label={t("rooms.modal.close")} type="button">
				<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M1 1L17 17M17 1L1 17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
			</button>

			<h3 class="room-modal-title" id="room-modal-title"></h3>

			<div class="room-modal-meta">
				<span class="room-modal-meta-item" id="room-modal-size"></span>
				<span class="room-modal-meta-sep"></span>
				<span class="room-modal-meta-label">{t("rooms.modal.guests.label")}</span>
				<span class="room-modal-guests" id="room-modal-guests"></span>
			</div>

			<p class="room-modal-beds" id="room-modal-beds"></p>

			<h4 class="room-modal-subtitle">{t("rooms.modal.features.title")}</h4>
			<div class="room-modal-features" id="room-modal-features"></div>

			<div class="room-modal-tags" id="room-modal-tags"></div>

			<p class="room-modal-desc" id="room-modal-desc"></p>

			<a class="room-modal-cta" id="room-modal-cta" href={bookingUrl} target="_blank" rel="noopener noreferrer">
				{t("rooms.modal.cta")}
			</a>
		</div>
	</div>
</div>

<script type="application/json" id="rooms-data" set:html={JSON.stringify(rooms)}></script>

<script>
import { gsap } from "gsap";
import { ScrollTrigger } from "gsap/ScrollTrigger";

gsap.registerPlugin(ScrollTrigger);

const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

if (!reduced) {

  /* ── 1. Header: línea se expande + título entra desde la izquierda ── */
  const headerAnim = gsap.utils.toArray<HTMLElement>(".rooms-header-anim");

  gsap.set(headerAnim[0], { scaleX: 0, transformOrigin: "left center" }); // línea
  gsap.set(headerAnim[1], { opacity: 0, x: -24 });                        // título

  ScrollTrigger.create({
    trigger: "#habitaciones",
    start: "top 82%",
    once: true,
    onEnter: () => {
      gsap.to(headerAnim[0], {
        scaleX: 1,
        duration: 0.7,
        ease: "power3.out",
      });
      gsap.to(headerAnim[1], {
        opacity: 1,
        x: 0,
        duration: 0.7,
        ease: "power3.out",
        delay: 0.15,
      });
    },
  });

  /* ── 2. Cards: entrada escalonada en cascada ─────────────────────────
     Cada card entra desde abajo con un delay progresivo.
     Las imágenes tienen un efecto de reveal con clip-path.
  ──────────────────────────────────────────────────────────────────── */
  const cards = gsap.utils.toArray<HTMLElement>(".room-card");

  // Estado inicial: cards invisibles y desplazadas hacia abajo
  gsap.set(cards, { opacity: 0, y: 40 });

  // Imágenes: clip-path revela de izquierda a derecha
  const images = gsap.utils.toArray<HTMLElement>(".room-image-link img");
  gsap.set(images, { clipPath: "inset(0 100% 0 0)", scale: 1.08 });

  ScrollTrigger.create({
    trigger: ".rooms-grid",
    start: "top 78%",
    once: true,
    onEnter: () => {

      // Cards entran escalonadas
      gsap.to(cards, {
        opacity: 1,
        y: 0,
        duration: 0.75,
        ease: "power3.out",
        stagger: {
          amount: 0.45,   // tiempo total del stagger entre las 4 cards
          from: "start",
        },
      });

      // Imágenes: clip-path se revela + escala vuelve a 1
      gsap.to(images, {
        clipPath: "inset(0 0% 0 0)",
        scale: 1,
        duration: 0.85,
        ease: "power3.out",
        stagger: {
          amount: 0.45,
          from: "start",
        },
        delay: 0.08,
      });

    },
  });

  /* ── 3. Hover en imagen: zoom suave gestionado por GSAP ─────────────
     Reemplaza la transición CSS del hover para mayor control.
     GSAP da curva de ease más rica que CSS transition.
  ──────────────────────────────────────────────────────────────────── */
  cards.forEach((card) => {
    const img = card.querySelector<HTMLElement>(".room-image-link img");
    if (!img) return;

    card.addEventListener("mouseenter", () => {
      gsap.to(img, { scale: 1.06, duration: 0.55, ease: "power2.out" });
    });

    card.addEventListener("mouseleave", () => {
      gsap.to(img, { scale: 1, duration: 0.55, ease: "power2.out" });
    });
  });

  /* ── 4. Hover en botón: micro-interacción de escala ─────────────────
     El botón se eleva ligeramente al hacer hover.
  ──────────────────────────────────────────────────────────────────── */
  const btns = gsap.utils.toArray<HTMLElement>(".room-book-btn");

  btns.forEach((btn) => {
    btn.addEventListener("mouseenter", () => {
      gsap.to(btn, { y: -2, duration: 0.22, ease: "power2.out" });
    });
    btn.addEventListener("mouseleave", () => {
      gsap.to(btn, { y: 0, duration: 0.22, ease: "power2.in" });
    });
  });

} else {
  // prefers-reduced-motion: mostrar todo directamente sin animación
  gsap.set(".rooms-header-anim", { opacity: 1, x: 0, scaleX: 1 });
  gsap.set(".room-card", { opacity: 1, y: 0 });
  gsap.set(".room-image-link img", { clipPath: "inset(0 0% 0 0)", scale: 1 });
}

/* ══════════════════════════════════════════════════════════
   MODAL — apertura, galería y controles
══════════════════════════════════════════════════════════ */
type RoomData = {
  title: string;
  longDescription: string;
  size: string;
  guests: number;
  beds: string;
  features: string[];
  tags: string[];
  images: string[];
};

const dataEl = document.getElementById("rooms-data");
const rooms: RoomData[] = dataEl ? JSON.parse(dataEl.textContent || "[]") : [];

const modal     = document.getElementById("room-modal")!;
const mainImg   = document.getElementById("room-modal-main-img") as HTMLImageElement;
const counter   = document.getElementById("room-modal-counter")!;
const thumbsBox = document.getElementById("room-modal-thumbs")!;
const titleEl   = document.getElementById("room-modal-title")!;
const sizeEl    = document.getElementById("room-modal-size")!;
const guestsEl  = document.getElementById("room-modal-guests")!;
const bedsEl    = document.getElementById("room-modal-beds")!;
const featsEl   = document.getElementById("room-modal-features")!;
const tagsEl    = document.getElementById("room-modal-tags")!;
const descEl    = document.getElementById("room-modal-desc")!;
const prevBtn   = document.getElementById("room-modal-prev")!;
const nextBtn   = document.getElementById("room-modal-next")!;

// Iconos para "Características" (estilo SimpleBooking)
const FEATURES: Record<string, { label: string; svg: string }> = {
  ac:      { label: "Aire acondicionado", svg: '<path d="M12 2v20M12 7l3-3M12 7 9 4M12 17l3 3M12 17l-3 3M2 12h20M7 12 4 9M7 12l-3 3M17 12l3-3M17 12l3 3"/>' },
  balcony: { label: "Balcón",             svg: '<path d="M3 21h18M5 21V10h14v11M9 21v-5h6v5M4 10l8-6 8 6"/>' },
  pool:    { label: "Vistas a la piscina", svg: '<path d="M2 12c1.5 1.5 3.5 1.5 5 0s3.5-1.5 5 0 3.5 1.5 5 0M2 17c1.5 1.5 3.5 1.5 5 0s3.5-1.5 5 0 3.5 1.5 5 0M12 4a3 3 0 1 1-6 0M9 7v3"/>' },
  wifi:    { label: "Wi-Fi libre",        svg: '<path d="M5 12.55a11 11 0 0 1 14 0M8.5 16.1a6 6 0 0 1 7 0M2 8.82a15 15 0 0 1 20 0M12 20h.01"/>' },
};

let currentRoom: RoomData | null = null;
let imgIdx = 0;
let isOpen = false;

function renderGallery() {
  if (!currentRoom) return;
  const imgs = currentRoom.images;
  mainImg.src = imgs[imgIdx];
  mainImg.alt = `${currentRoom.title} — imagen ${imgIdx + 1}`;
  counter.textContent = `${imgIdx + 1} / ${imgs.length}`;
  thumbsBox.querySelectorAll<HTMLElement>(".room-modal-thumb").forEach((t, i) => {
    t.classList.toggle("room-modal-thumb--active", i === imgIdx);
  });
}

function openModal(idx: number) {
  currentRoom = rooms[idx];
  if (!currentRoom) return;
  imgIdx = 0;

  titleEl.textContent  = currentRoom.title;
  sizeEl.textContent   = currentRoom.size;
  bedsEl.textContent   = currentRoom.beds;
  descEl.textContent   = currentRoom.longDescription;

  // Huéspedes: iconos de persona
  guestsEl.innerHTML = Array.from({ length: currentRoom.guests })
    .map(() => '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 12a5 5 0 1 0 0-10 5 5 0 0 0 0 10zm0 2c-5 0-9 2.5-9 6v2h18v-2c0-3.5-4-6-9-6z"/></svg>')
    .join("");

  // Características con icono
  featsEl.innerHTML = currentRoom.features
    .map((f) => {
      const cfg = FEATURES[f];
      if (!cfg) return "";
      return `<span class="room-modal-feature"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">${cfg.svg}</svg>${cfg.label}</span>`;
    })
    .join("");

  // Tags
  tagsEl.innerHTML = currentRoom.tags
    .map((t) => `<span class="room-modal-tag">${t}</span>`)
    .join("");

  // Thumbnails
  thumbsBox.innerHTML = currentRoom.images
    .map((src, i) => `<button type="button" class="room-modal-thumb" data-thumb="${i}"><img src="${src}" alt="" loading="lazy" /></button>`)
    .join("");
  thumbsBox.querySelectorAll<HTMLElement>(".room-modal-thumb").forEach((t) => {
    t.addEventListener("click", () => { imgIdx = Number(t.dataset.thumb); renderGallery(); });
  });

  renderGallery();

  modal.classList.add("room-modal--open");
  modal.removeAttribute("aria-hidden");
  document.body.style.overflow = "hidden";
  isOpen = true;
}

function closeModal() {
  modal.classList.remove("room-modal--open");
  modal.setAttribute("aria-hidden", "true");
  document.body.style.overflow = "";
  isOpen = false;
}

function navImg(dir: number) {
  if (!currentRoom) return;
  const n = currentRoom.images.length;
  imgIdx = (imgIdx + dir + n) % n;
  renderGallery();
}

// Abrir desde cualquier botón con data-room-modal
document.querySelectorAll<HTMLElement>("[data-room-modal]").forEach((el) => {
  el.addEventListener("click", () => openModal(Number(el.dataset.roomModal)));
});

// Cerrar
document.querySelectorAll<HTMLElement>("[data-room-close]").forEach((el) => {
  el.addEventListener("click", closeModal);
});

prevBtn.addEventListener("click", () => navImg(-1));
nextBtn.addEventListener("click", () => navImg(1));

document.addEventListener("keydown", (e) => {
  if (!isOpen) return;
  if (e.key === "Escape") closeModal();
  if (e.key === "ArrowLeft") navImg(-1);
  if (e.key === "ArrowRight") navImg(1);
});

// Swipe en móvil
let touchX = 0;
mainImg.addEventListener("touchstart", (e) => { touchX = e.touches[0].clientX; }, { passive: true });
mainImg.addEventListener("touchend", (e) => {
  const delta = touchX - e.changedTouches[0].clientX;
  if (Math.abs(delta) > 50) navImg(delta > 0 ? 1 : -1);
});
</script>