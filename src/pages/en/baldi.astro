---
import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';

const includes = [
  '1 night accommodation at Downtown La Fortuna Boutique Hotel',
  'Day pass at Baldi Hot Springs (10AM – 10PM)',
  'Access to 25 thermal pools, water slides and sauna',
  'Breakfast (à la carte or buffet)',
  'Lunch and dinner at Baldi Hot Springs (buffet style)',
  'Welcome drink',
  '2×1 cocktails at Selva Negra Bar or María Bonita · 12 noon–5 p.m.',
  'Free private parking',
  'Access to hotel pool',
  'Free WiFi throughout the property',
];

const pricing = [
  { label: 'Adult',          sub: 'per person · double occupancy', price: '₡60,000', highlight: true  },
  { label: 'Child 6–10 yrs', sub: 'special price per child',       price: '₡35,000', highlight: false },
  { label: 'Child 0–5 yrs',  sub: 'no additional cost',            price: 'FREE',    highlight: false },
];

const rooms = [
  { name: 'Standard Double',  img: 'https://i.ibb.co/SwhzWkZR/Estandar-Doble4.png', tag: 'Double' },
  { name: 'Standard Triple',  img: 'https://i.ibb.co/PGZPHP1N/Estandar-Doble3.png', tag: 'Triple' },
  { name: 'Superior',         img: 'https://i.ibb.co/kshJL68d/superior3.png',       tag: 'Superior' },
  { name: 'Tropical Family',  img: 'https://i.ibb.co/gbVPz97Z/tropical3.png',        tag: 'Family' },
];

const policies = [
  { color: '#4ade80', range: 'More than 30 days before check-in',       charge: 'No charge' },
  { color: '#b90024', range: 'Between 15 and 30 days before check-in',  charge: '50% charge of the total reservation' },
  { color: '#f87171', range: 'Less than 15 days before check-in',       charge: '100% charge of the total reservation' },
];
---

<Layout
  title="Baldi Package | Downtown La Fortuna Boutique Hotel"
  description="Package with Baldi Hot Springs admission, accommodation at La Fortuna Downtown, and access to all hotel experiences."
  image="https://i.ibb.co/Xr70WzXY/baldi3.png"
>
  <Fragment slot="head">
    <meta name="keywords" content="La Fortuna Costa Rica packages, hot springs accommodation La Fortuna, Baldi Hot Springs package, hotel La Fortuna center, boutique hotel La Fortuna, Downtown La Fortuna hotel" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="author" content="Downtown La Fortuna Boutique Hotel" />
    <link rel="alternate" hreflang="en" href="https://lafortunadowntown.com/en/baldi" />
    <link rel="alternate" hreflang="es-CR" href="https://lafortunadowntown.com/baldi" />
  </Fragment>

  <main>


    <section class="baldi-hero" id="inicio">
      <div
        class="baldi-hero-bg"
        style="background-image:url('https://i.ibb.co/Xr70WzXY/baldi3.png')"
        aria-hidden="true"
      ></div>
      <div class="baldi-hero-overlay" aria-hidden="true"></div>

      <div class="baldi-hero-content">
        <p class="baldi-hero-eyebrow">Exclusive offer · La Fortuna</p>
        <h1 class="baldi-hero-title">
          Accommodation +<br/>Baldi Day Pass
        </h1>
        <p class="baldi-hero-from">from:</p>
        <p class="baldi-hero-price">₡60,000 <span>incl.</span></p>
        <p class="baldi-hero-price-sub">per person double occupancy</p>

        <div class="baldi-hero-badge">
          Accommodation · Baldi Pass · Lunch · Dinner · Breakfast
        </div>

        <div class="baldi-hero-ctas">
          <a
            href="https://wa.me/50685274677?text=Hello,%20I'm%20interested%20in%20the%20Accommodation%20+%20Baldi%20package%20(%E2%82%A160%2C000)"
            class="baldi-btn baldi-btn--primary"
            target="_blank"
            rel="noopener noreferrer"
          >Book Now</a>
          <a href="#detalles" class="baldi-btn baldi-btn--outline">
            View package details
          </a>
        </div>

        <p class="baldi-hero-finepri">
          *Valid July 1 to August 31 · Children 0–5 FREE · Restrictions apply*
        </p>
      </div>
    </section>


    <div class="baldi-countdown">
      <div class="baldi-countdown-inner">
        <span class="baldi-countdown-label">
          Valid July 1 to August 31
        </span>
        <div class="baldi-countdown-timer">
          <div class="baldi-cd-unit"><span id="cd-days">--</span><em>Days</em></div>
          <div class="baldi-cd-sep">:</div>
          <div class="baldi-cd-unit"><span id="cd-hours">--</span><em>Hours</em></div>
          <div class="baldi-cd-sep">:</div>
          <div class="baldi-cd-unit"><span id="cd-mins">--</span><em>Min</em></div>
          <div class="baldi-cd-sep">:</div>
          <div class="baldi-cd-unit"><span id="cd-secs">--</span><em>Sec</em></div>
        </div>
      </div>
    </div>


    <section class="baldi-section baldi-why">
      <div class="baldi-container">
        <p class="baldi-eyebrow">Why choose us?</p>
        <h2 class="baldi-section-title">The best experience at the best price</h2>
        <div class="baldi-why-grid">
          <div class="baldi-why-card">
            <div class="baldi-why-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <h3>Best prices</h3>
            <p>Special prices better than high season. Save without sacrificing quality!</p>
          </div>
          <div class="baldi-why-card">
            <div class="baldi-why-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </div>
            <h3>Most central hotel</h3>
            <p>Located in the heart of La Fortuna, steps from the central park and near all attractions.</p>
          </div>
          <div class="baldi-why-card">
            <div class="baldi-why-icon">
              <svg width="30" height="30" viewBox="0 0 1024 1024" fill="currentColor" aria-hidden="true">
                <g transform="translate(0,1024) scale(0.1,-0.1)" fill="currentColor" stroke="none">
                  <path d="M5381 8944 c-46 -8 -123 -27 -172 -44 -473 -158 -822 -565 -935 -1090 -26 -120 -26 -410 0 -530 35 -164 101 -322 194 -465 62 -97 106 -150 259 -307 190 -196 258 -308 283 -465 31 -192 -43 -360 -264 -607 -262 -293 -369 -482 -423 -753 -26 -131 -24 -415 4 -543 86 -396 367 -750 738 -931 118 -57 198 -86 266 -95 56 -7 61 1 23 37 -14 13 -46 51 -71 83 -215 287 -289 649 -197 971 57 199 141 323 367 539 320 306 453 493 543 761 55 167 77 321 71 500 -11 276 -80 495 -230 723 -80 122 -139 193 -301 361 -257 267 -363 456 -402 714 -65 423 183 850 629 1087 26 14 47 28 47 32 0 35 -274 49 -429 22z"/>
                  <path d="M3640 7749 c-90 -14 -259 -72 -338 -116 -86 -48 -193 -137 -264 -221 -243 -284 -302 -687 -148 -1019 55 -119 98 -178 227 -315 169 -179 211 -251 228 -389 8 -64 -13 -166 -49 -237 -34 -67 -100 -153 -194 -255 -151 -163 -230 -300 -274 -473 -31 -123 -31 -380 0 -496 96 -357 375 -650 729 -766 71 -24 173 -38 173 -25 0 5 -25 33 -56 63 -117 115 -217 299 -250 461 -24 120 -16 278 21 379 47 128 88 183 295 395 249 254 331 374 394 573 139 442 16 896 -338 1247 -188 186 -241 263 -276 400 -37 146 -25 255 47 405 40 82 58 107 137 185 55 54 117 104 155 125 36 19 66 41 69 47 10 32 -164 51 -288 32z"/>
                  <path d="M7103 7746 c-633 -120 -990 -786 -723 -1345 55 -115 115 -196 241 -327 176 -182 227 -285 217 -436 -10 -136 -65 -237 -219 -404 -125 -134 -183 -213 -235 -319 -64 -132 -85 -223 -91 -390 -5 -125 -2 -152 20 -253 79 -348 324 -634 670 -781 88 -38 220 -71 233 -58 3 3 -27 44 -68 90 -84 97 -126 163 -173 274 -102 237 -83 486 52 690 21 32 119 142 219 244 196 201 284 319 347 464 158 359 113 789 -116 1132 -28 43 -119 148 -202 233 -83 85 -165 176 -183 202 -138 201 -147 429 -25 638 55 93 171 208 271 265 45 26 82 51 82 55 0 31 -202 48 -317 26z"/>
                  <path d="M5486 4540 c-40 -13 -72 -44 -121 -120 -159 -243 -192 -578 -85 -842 44 -107 105 -207 187 -304 42 -49 84 -102 94 -119 28 -44 25 -107 -6 -144 -37 -44 -82 -55 -194 -48 -345 21 -741 269 -966 607 -177 264 -265 540 -265 828 0 156 14 148 -231 136 l-182 -9 -33 -39 c-19 -21 -47 -73 -63 -115 -76 -201 -64 -387 36 -571 42 -78 74 -119 170 -222 83 -90 102 -134 84 -191 -31 -93 -139 -126 -300 -92 -228 48 -453 168 -617 331 -186 184 -297 403 -343 673 -11 68 -23 127 -27 132 -8 14 -63 11 -239 -11 -749 -95 -1357 -245 -1446 -358 -93 -119 163 -227 751 -316 91 -14 278 -39 415 -55 138 -17 266 -35 286 -40 47 -14 115 -74 140 -124 16 -31 20 -53 17 -94 -9 -104 -66 -146 -307 -226 -264 -89 -408 -163 -462 -238 -69 -97 -11 -211 156 -304 219 -121 688 -256 1180 -339 719 -121 1715 -184 2480 -157 1066 37 2003 184 2600 406 142 53 249 112 317 173 178 164 56 301 -405 458 -93 31 -187 69 -209 85 -110 73 -117 200 -16 296 62 59 106 71 471 124 379 54 439 65 642 115 148 37 272 88 318 131 77 75 -10 156 -243 227 -360 108 -781 184 -1515 271 -22 2 -107 9 -189 15 -170 13 -181 10 -217 -62 -68 -133 -92 -289 -66 -415 32 -149 90 -257 209 -391 93 -104 116 -155 99 -212 -33 -109 -159 -135 -368 -74 -397 115 -730 440 -848 829 -31 101 -55 240 -55 315 0 41 -5 61 -16 71 -13 11 -78 14 -303 16 -157 1 -299 -2 -315 -7z"/>
                  <path d="M8013 3525 c-56 -24 -70 -79 -29 -120 13 -13 55 -33 97 -45 319 -92 476 -157 602 -250 96 -71 154 -159 156 -235 1 -43 -41 -126 -89 -178 -114 -124 -374 -255 -700 -352 -776 -230 -2136 -374 -3190 -336 -755 27 -1357 85 -1840 176 -41 8 -127 24 -190 35 -718 134 -1228 359 -1306 577 -34 98 -1 188 103 282 111 100 270 173 545 251 190 54 218 70 218 126 0 49 -37 74 -111 74 -129 0 -555 -97 -819 -187 -455 -154 -732 -338 -834 -553 -29 -60 -31 -73 -31 -171 0 -106 0 -107 45 -195 36 -71 63 -107 135 -179 113 -114 232 -193 450 -300 331 -163 769 -299 1350 -420 556 -115 1082 -181 1825 -227 277 -17 1311 -17 1570 0 596 40 908 72 1354 143 750 118 1386 294 1801 499 203 100 326 182 440 292 259 249 269 494 30 728 -245 241 -813 467 -1419 565 -115 18 -122 18 -163 0z"/>
                </g>
              </svg>
            </div>
            <h3>Largest hot springs</h3>
            <p>Access to Baldi Hot Springs, the world's largest thermal complex with 25 pools heated by Arenal Volcano.</p>
          </div>
        </div>
      </div>
    </section>


    <section class="baldi-section baldi-includes-section" id="detalles">
      <div class="baldi-container">
        <p class="baldi-eyebrow">Complete package</p>
        <h2 class="baldi-section-title">What's included in your package?</h2>

        <div class="baldi-feat-grid">
          <div class="baldi-feat-card">
            <div class="baldi-feat-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
            </div>
            <h3>Luxury Accommodation</h3>
            <p>1 night at Downtown La Fortuna Boutique Hotel. Pool, WiFi and free private parking included.</p>
          </div>
          <div class="baldi-feat-card baldi-feat-card--highlight">
            <div class="baldi-feat-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
            </div>
            <h3>Full meals</h3>
            <p>À la carte breakfast + welcome drink + buffet lunch and dinner at Baldi + 2×1 cocktails 12–5 pm.</p>
          </div>
          <div class="baldi-feat-card">
            <div class="baldi-feat-icon">
              <svg width="30" height="30" viewBox="0 0 1024 1024" fill="currentColor" aria-hidden="true">
                <g transform="translate(0,1024) scale(0.1,-0.1)" fill="currentColor" stroke="none">
                  <path d="M5381 8944 c-46 -8 -123 -27 -172 -44 -473 -158 -822 -565 -935 -1090 -26 -120 -26 -410 0 -530 35 -164 101 -322 194 -465 62 -97 106 -150 259 -307 190 -196 258 -308 283 -465 31 -192 -43 -360 -264 -607 -262 -293 -369 -482 -423 -753 -26 -131 -24 -415 4 -543 86 -396 367 -750 738 -931 118 -57 198 -86 266 -95 56 -7 61 1 23 37 -14 13 -46 51 -71 83 -215 287 -289 649 -197 971 57 199 141 323 367 539 320 306 453 493 543 761 55 167 77 321 71 500 -11 276 -80 495 -230 723 -80 122 -139 193 -301 361 -257 267 -363 456 -402 714 -65 423 183 850 629 1087 26 14 47 28 47 32 0 35 -274 49 -429 22z"/>
                  <path d="M3640 7749 c-90 -14 -259 -72 -338 -116 -86 -48 -193 -137 -264 -221 -243 -284 -302 -687 -148 -1019 55 -119 98 -178 227 -315 169 -179 211 -251 228 -389 8 -64 -13 -166 -49 -237 -34 -67 -100 -153 -194 -255 -151 -163 -230 -300 -274 -473 -31 -123 -31 -380 0 -496 96 -357 375 -650 729 -766 71 -24 173 -38 173 -25 0 5 -25 33 -56 63 -117 115 -217 299 -250 461 -24 120 -16 278 21 379 47 128 88 183 295 395 249 254 331 374 394 573 139 442 16 896 -338 1247 -188 186 -241 263 -276 400 -37 146 -25 255 47 405 40 82 58 107 137 185 55 54 117 104 155 125 36 19 66 41 69 47 10 32 -164 51 -288 32z"/>
                  <path d="M7103 7746 c-633 -120 -990 -786 -723 -1345 55 -115 115 -196 241 -327 176 -182 227 -285 217 -436 -10 -136 -65 -237 -219 -404 -125 -134 -183 -213 -235 -319 -64 -132 -85 -223 -91 -390 -5 -125 -2 -152 20 -253 79 -348 324 -634 670 -781 88 -38 220 -71 233 -58 3 3 -27 44 -68 90 -84 97 -126 163 -173 274 -102 237 -83 486 52 690 21 32 119 142 219 244 196 201 284 319 347 464 158 359 113 789 -116 1132 -28 43 -119 148 -202 233 -83 85 -165 176 -183 202 -138 201 -147 429 -25 638 55 93 171 208 271 265 45 26 82 51 82 55 0 31 -202 48 -317 26z"/>
                  <path d="M5486 4540 c-40 -13 -72 -44 -121 -120 -159 -243 -192 -578 -85 -842 44 -107 105 -207 187 -304 42 -49 84 -102 94 -119 28 -44 25 -107 -6 -144 -37 -44 -82 -55 -194 -48 -345 21 -741 269 -966 607 -177 264 -265 540 -265 828 0 156 14 148 -231 136 l-182 -9 -33 -39 c-19 -21 -47 -73 -63 -115 -76 -201 -64 -387 36 -571 42 -78 74 -119 170 -222 83 -90 102 -134 84 -191 -31 -93 -139 -126 -300 -92 -228 48 -453 168 -617 331 -186 184 -297 403 -343 673 -11 68 -23 127 -27 132 -8 14 -63 11 -239 -11 -749 -95 -1357 -245 -1446 -358 -93 -119 163 -227 751 -316 91 -14 278 -39 415 -55 138 -17 266 -35 286 -40 47 -14 115 -74 140 -124 16 -31 20 -53 17 -94 -9 -104 -66 -146 -307 -226 -264 -89 -408 -163 -462 -238 -69 -97 -11 -211 156 -304 219 -121 688 -256 1180 -339 719 -121 1715 -184 2480 -157 1066 37 2003 184 2600 406 142 53 249 112 317 173 178 164 56 301 -405 458 -93 31 -187 69 -209 85 -110 73 -117 200 -16 296 62 59 106 71 471 124 379 54 439 65 642 115 148 37 272 88 318 131 77 75 -10 156 -243 227 -360 108 -781 184 -1515 271 -22 2 -107 9 -189 15 -170 13 -181 10 -217 -62 -68 -133 -92 -289 -66 -415 32 -149 90 -257 209 -391 93 -104 116 -155 99 -212 -33 -109 -159 -135 -368 -74 -397 115 -730 440 -848 829 -31 101 -55 240 -55 315 0 41 -5 61 -16 71 -13 11 -78 14 -303 16 -157 1 -299 -2 -315 -7z"/>
                  <path d="M8013 3525 c-56 -24 -70 -79 -29 -120 13 -13 55 -33 97 -45 319 -92 476 -157 602 -250 96 -71 154 -159 156 -235 1 -43 -41 -126 -89 -178 -114 -124 -374 -255 -700 -352 -776 -230 -2136 -374 -3190 -336 -755 27 -1357 85 -1840 176 -41 8 -127 24 -190 35 -718 134 -1228 359 -1306 577 -34 98 -1 188 103 282 111 100 270 173 545 251 190 54 218 70 218 126 0 49 -37 74 -111 74 -129 0 -555 -97 -819 -187 -455 -154 -732 -338 -834 -553 -29 -60 -31 -73 -31 -171 0 -106 0 -107 45 -195 36 -71 63 -107 135 -179 113 -114 232 -193 450 -300 331 -163 769 -299 1350 -420 556 -115 1082 -181 1825 -227 277 -17 1311 -17 1570 0 596 40 908 72 1354 143 750 118 1386 294 1801 499 203 100 326 182 440 292 259 249 269 494 30 728 -245 241 -813 467 -1419 565 -115 18 -122 18 -163 0z"/>
                </g>
              </svg>
            </div>
            <h3>Baldi Hot Springs</h3>
            <p>Full day pass (10AM – 10PM): 25 thermal pools, water slides, natural sauna and thermal garden.</p>
          </div>
        </div>

        <div class="baldi-checklist-wrap">
          <p class="baldi-checklist-title">Everything that is included</p>
          <ul class="baldi-checklist">
            {includes.map(item => (
              <li set:html={item}></li>
            ))}
          </ul>
        </div>
      </div>
    </section>


    <section class="baldi-section baldi-pricing-section">
      <div class="baldi-container baldi-container--narrow">
        <p class="baldi-eyebrow">Rates</p>
        <h2 class="baldi-section-title">Prices</h2>
        <div class="baldi-pricing-grid">
          {pricing.map(tier => (
            <div class={`baldi-price-card${tier.highlight ? ' baldi-price-card--highlight' : ''}`}>
              <p class="baldi-price-label">{tier.label}</p>
              <p class="baldi-price-sub">{tier.sub}</p>
              <p class="baldi-price-amount">{tier.price}</p>
            </div>
          ))}
        </div>
        <p class="baldi-pricing-note">
          ✨ Prices in colones include taxes. Valid from July 1 to August 31, 2026.
        </p>
      </div>
    </section>


    <section class="baldi-section baldi-rooms-section">
      <div class="baldi-container">
        <p class="baldi-eyebrow">Our rooms</p>
        <h2 class="baldi-section-title">A lodging experience in the heart of La Fortuna</h2>
        <p class="baldi-section-sub">Room assigned based on availability and number of guests in the reservation.</p>
        <div class="baldi-rooms-grid">
          {rooms.map(room => (
            <div class="baldi-room-card">
              <div class="baldi-room-img-wrap">
                <img src={room.img} alt={room.name} loading="lazy" decoding="async" />
                <span class="baldi-room-tag">{room.tag}</span>
              </div>
              <div class="baldi-room-body">
                <p class="baldi-room-name">{room.name}</p>
                <p class="baldi-room-note">Check availability</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <section class="baldi-section baldi-exp-section">
      <div class="baldi-container">
        <p class="baldi-eyebrow">The Baldi experience</p>
        <h2 class="baldi-section-title">Immerse yourself in the hot springs</h2>
        <div class="baldi-exp-grid">
          <div class="baldi-exp-img-wrap">
            <img
              src="https://i.ibb.co/0R16Yc59/baldi1.png"
              alt="Baldi Hot Springs La Fortuna thermal pools"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="baldi-exp-text">
            <h3>The Baldi Experience</h3>
            <p>
              Immerse yourself in mineral-rich waters, naturally heated by the heart of
              Arenal Volcano. 25 thermal pools designed for total relaxation: from
              calm pools to water slides and a natural sauna.
            </p>
            <p>
              The world's largest thermal complex awaits you with the most extensive
              thermal garden in the area, dining included and an unmatched atmosphere with volcano views.
            </p>
            <a
              href="https://wa.me/50685274677?text=Hello,%20I'm%20interested%20in%20the%20Accommodation%20+%20Baldi%20package"
              class="baldi-btn baldi-btn--dark"
              target="_blank"
              rel="noopener noreferrer"
            >Book now →</a>
          </div>
        </div>


        <div class="baldi-exp-img2-wrap">
          <img
            src="https://i.ibb.co/KjXW6MkG/baldi2.png"
            alt="Baldi Hot Springs pools"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </section>


    <section class="baldi-section baldi-cta-section">
      <div class="baldi-container baldi-container--narrow" style="text-align:center">
        <p class="baldi-eyebrow baldi-eyebrow--light">Limited spots</p>
        <h2 class="baldi-cta-title">Secure your stay</h2>
        <p class="baldi-cta-sub">Check availability and book your package directly on WhatsApp. Offer valid until August 31.</p>
        <a
          href="https://wa.me/50685274677?text=Hello,%20I'm%20interested%20in%20the%20*Accommodation%20+%20Baldi*%20package%20(%E2%82%A160%2C000%20per%20person).%20I'd%20like%20to%20check%20availability."
          class="baldi-btn baldi-btn--wa"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="flex-shrink:0">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Check availability on WhatsApp
        </a>
      </div>
    </section>


    <section class="baldi-section baldi-policy-section">
      <div class="baldi-container baldi-container--narrow">
        <p class="baldi-eyebrow">Policies</p>
        <h2 class="baldi-section-title">Cancellation policies</h2>
