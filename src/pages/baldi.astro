---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const includes = [
  'Alojamiento 1 noche en Downtown La Fortuna Boutique Hotel',
  'Pase del día en Baldi Hot Springs (10AM – 10PM)',
  'Acceso a 25 piscinas termales, toboganes y sauna',
  'Desayuno (a la carta o buffet)',
  'Almuerzo y Cena en Baldi Hot Springs (estilo buffet)',
  'Bebida de bienvenida',
  'Cocteles 2×1 en Selva Negra Bar o María Bonita · 12 m.d.–5 p.m.',
  'Parqueo privado gratuito',
  'Acceso a piscina del hotel',
  'WiFi gratuito en todas las instalaciones',
];

const pricing = [
  { label: 'Adulto',         sub: 'por persona · ocupación doble', price: '₡49.800', highlight: true  },
  { label: 'Niño 6–10 años', sub: 'precio especial por niño',      price: '₡35.000', highlight: false },
  { label: 'Niño 0–5 años',  sub: 'sin costo adicional',           price: 'GRATIS',  highlight: false },
];

const rooms = [
  { name: 'Standard Doble',  img: 'https://i.ibb.co/SwhzWkZR/Estandar-Doble4.png', tag: 'Doble' },
  { name: 'Standard Triple', img: 'https://i.ibb.co/PGZPHP1N/Estandar-Doble3.png', tag: 'Triple' },
  { name: 'Superior',        img: 'https://i.ibb.co/kshJL68d/superior3.png',       tag: 'Superior' },
  { name: 'Tropical Family', img: 'https://i.ibb.co/gbVPz97Z/tropical3.png',        tag: 'Familiar' },
];

const policies = [
  { color: '#4ade80', range: 'Más de 30 días antes del ingreso',     charge: 'Sin cargo · cancelación gratuita' },
  { color: '#facc15', range: 'Entre 15 y 30 días antes del ingreso', charge: 'Cargo del 50% del total de la reserva' },
  { color: '#f87171', range: 'Menos de 15 días antes del ingreso',   charge: 'Cargo del 100% del total de la reserva' },
];
---

<Layout
  title="Paquete Hospedaje + Baldi Hot Springs | ₡49.800 i.i | Downtown La Fortuna"
  description="Paquete para nacionales en La Fortuna: 1 noche en hotel boutique céntrico + Pase del día en Baldi Hot Springs (10AM–10PM) + Desayuno + Almuerzo y Cena. Desde ₡49.800 i.i por persona. Niños 0–5 GRATIS. Válido del 10 abril al 30 junio 2026."
  image="https://i.ibb.co/Xr70WzXY/baldi3.png"
>
  <Fragment slot="head">
    <meta name="keywords" content="paquetes La Fortuna Costa Rica, hospedaje aguas termales La Fortuna, Baldi Hot Springs paquete, hotel La Fortuna centro, paquetes nacionales Costa Rica, hotel boutique La Fortuna, Downtown La Fortuna hotel" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="author" content="Downtown La Fortuna Boutique Hotel" />
    <link rel="alternate" hreflang="es-CR" href="https://lafortunadowntown.com/baldi" />

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Hotel",
          "@id": "https://lafortunadowntown.com/#hotel",
          "name": "Downtown La Fortuna Boutique Hotel",
          "url": "https://lafortunadowntown.com",
          "telephone": "+50640002027",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "25 m sur de la iglesia católica La Fortuna",
            "addressLocality": "La Fortuna de San Carlos",
            "addressRegion": "Alajuela",
            "addressCountry": "CR"
          }
        },
        {
          "@type": "Product",
          "@id": "https://lafortunadowntown.com/baldi#paquete",
          "name": "Paquete Hospedaje + Pase del Día Baldi Hot Springs",
          "description": "1 noche en Downtown La Fortuna Boutique Hotel + Pase del día en Baldi Hot Springs (10AM–10PM, 25 piscinas) + Desayuno + Almuerzo y Cena buffet + Bebida de bienvenida + Cocteles 2×1. Niños 0–5 sin costo.",
          "image": "https://i.ibb.co/Xr70WzXY/baldi3.png",
          "offers": {
            "@type": "Offer",
            "price": "49800",
            "priceCurrency": "CRC",
            "priceValidUntil": "2026-06-30",
            "availability": "https://schema.org/InStock",
            "validFrom": "2026-04-10",
            "validThrough": "2026-06-30"
          }
        },
        {
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "¿Qué incluye el paquete Hospedaje + Baldi en La Fortuna?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "El paquete incluye: 1 noche de alojamiento, pase del día en Baldi Hot Springs (10AM–10PM, 25 piscinas), desayuno, almuerzo y cena buffet en Baldi, bebida de bienvenida, cocteles 2×1, parqueo y WiFi gratuitos."
              }
            },
            {
              "@type": "Question",
              "name": "¿Cuánto cuesta el paquete Baldi?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "₡49.800 i.i por persona en ocupación doble. Niños 0–5 GRATIS. Niños 6–10: ₡35.000."
              }
            },
            {
              "@type": "Question",
              "name": "¿Hasta cuándo es válida la oferta?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Válida del 10 de abril al 30 de junio de 2026. Sujeta a disponibilidad."
              }
            }
          ]
        }
      ]
    }
    </script>
  </Fragment>

  <main>

    
    <section class="baldi-hero" id="inicio">
      <div
        class="baldi-hero-bg"
        style="background-image:url('https://i.ibb.co/Xr70WzXY/baldi3.png')"
        aria-hidden="true"
      ></div>
      <div class="baldi-hero-overlay" aria-hidden="true"></div>

      <div class="baldi-hero-content">
        <p class="baldi-hero-eyebrow">Oferta exclusiva para nacionales · La Fortuna</p>
        <h1 class="baldi-hero-title">
          Hospedaje +<br/>Pase del Día Baldi
        </h1>
        <p class="baldi-hero-from">desde:</p>
        <p class="baldi-hero-price">₡49.800 <span>i.i</span></p>
        <p class="baldi-hero-price-sub">por persona en ocupación doble</p>

        <div class="baldi-hero-badge">
          Hospedaje · Pase a Baldi · Almuerzo · Cena · Desayuno
        </div>

        <div class="baldi-hero-ctas">
          <a
            href="https://wa.me/50685274677?text=Hola,%20me%20interesa%20el%20paquete%20Hospedaje%20+%20Baldi%20(%E2%82%A149.800%20i.i)"
            class="baldi-btn baldi-btn--primary"
            target="_blank"
            rel="noopener noreferrer"
          >Reservar Oferta</a>
          <a href="#detalles" class="baldi-btn baldi-btn--outline">
            Ver detalles del paquete
          </a>
        </div>

        <p class="baldi-hero-finepri">
          *Válido del 10 de abril al 30 de junio · Niños 0–5 GRATIS · Aplican restricciones*
        </p>
      </div>
    </section>

    
    <div class="baldi-countdown">
      <div class="baldi-countdown-inner">
        <span class="baldi-countdown-label">
          Válida del 10 de abril al 30 de junio
        </span>
        <div class="baldi-countdown-timer">
          <div class="baldi-cd-unit"><span id="cd-days">--</span><em>Días</em></div>
          <div class="baldi-cd-sep">:</div>
          <div class="baldi-cd-unit"><span id="cd-hours">--</span><em>Horas</em></div>
          <div class="baldi-cd-sep">:</div>
          <div class="baldi-cd-unit"><span id="cd-mins">--</span><em>Min</em></div>
          <div class="baldi-cd-sep">:</div>
          <div class="baldi-cd-unit"><span id="cd-secs">--</span><em>Seg</em></div>
        </div>
      </div>
    </div>

    
    <section class="baldi-section baldi-why">
      <div class="baldi-container">
        <p class="baldi-eyebrow">¿Por qué elegirnos?</p>
        <h2 class="baldi-section-title">La mejor experiencia al mejor precio</h2>
        <div class="baldi-why-grid">
          <div class="baldi-why-card">
            <div class="baldi-why-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <h3>Mejores precios</h3>
            <p>Precios especiales para nacionales, mejores que en temporada alta. ¡Ahorra sin sacrificar calidad!</p>
          </div>
          <div class="baldi-why-card">
            <div class="baldi-why-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </div>
            <h3>Hotel más céntrico</h3>
            <p>Ubicados en el corazón de La Fortuna, a pasos del parque central y cerca de todas las atracciones.</p>
          </div>
          <div class="baldi-why-card">
            <div class="baldi-why-icon">
              <svg width="30" height="30" viewBox="0 0 1024 1024" fill="currentColor" aria-hidden="true">
                <g transform="translate(0,1024) scale(0.1,-0.1)" fill="currentColor" stroke="none">
                  <path d="M5381 8944 c-46 -8 -123 -27 -172 -44 -473 -158 -822 -565 -935 -1090 -26 -120 -26 -410 0 -530 35 -164 101 -322 194 -465 62 -97 106 -150 259 -307 190 -196 258 -308 283 -465 31 -192 -43 -360 -264 -607 -262 -293 -369 -482 -423 -753 -26 -131 -24 -415 4 -543 86 -396 367 -750 738 -931 118 -57 198 -86 266 -95 56 -7 61 1 23 37 -14 13 -46 51 -71 83 -215 287 -289 649 -197 971 57 199 141 323 367 539 320 306 453 493 543 761 55 167 77 321 71 500 -11 276 -80 495 -230 723 -80 122 -139 193 -301 361 -257 267 -363 456 -402 714 -65 423 183 850 629 1087 26 14 47 28 47 32 0 35 -274 49 -429 22z"/>
                  <path d="M3640 7749 c-90 -14 -259 -72 -338 -116 -86 -48 -193 -137 -264 -221 -243 -284 -302 -687 -148 -1019 55 -119 98 -178 227 -315 169 -179 211 -251 228 -389 8 -64 -13 -166 -49 -237 -34 -67 -100 -153 -194 -255 -151 -163 -230 -300 -274 -473 -31 -123 -31 -380 0 -496 96 -357 375 -650 729 -766 71 -24 173 -38 173 -25 0 5 -25 33 -56 63 -117 115 -217 299 -250 461 -24 120 -16 278 21 379 47 128 88 183 295 395 249 254 331 374 394 573 139 442 16 896 -338 1247 -188 186 -241 263 -276 400 -37 146 -25 255 47 405 40 82 58 107 137 185 55 54 117 104 155 125 36 19 66 41 69 47 10 32 -164 51 -288 32z"/>
                  <path d="M7103 7746 c-633 -120 -990 -786 -723 -1345 55 -115 115 -196 241 -327 176 -182 227 -285 217 -436 -10 -136 -65 -237 -219 -404 -125 -134 -183 -213 -235 -319 -64 -132 -85 -223 -91 -390 -5 -125 -2 -152 20 -253 79 -348 324 -634 670 -781 88 -38 220 -71 233 -58 3 3 -27 44 -68 90 -84 97 -126 163 -173 274 -102 237 -83 486 52 690 21 32 119 142 219 244 196 201 284 319 347 464 158 359 113 789 -116 1132 -28 43 -119 148 -202 233 -83 85 -165 176 -183 202 -138 201 -147 429 -25 638 55 93 171 208 271 265 45 26 82 51 82 55 0 31 -202 48 -317 26z"/>
                  <path d="M5486 4540 c-40 -13 -72 -44 -121 -120 -159 -243 -192 -578 -85 -842 44 -107 105 -207 187 -304 42 -49 84 -102 94 -119 28 -44 25 -107 -6 -144 -37 -44 -82 -55 -194 -48 -345 21 -741 269 -966 607 -177 264 -265 540 -265 828 0 156 14 148 -231 136 l-182 -9 -33 -39 c-19 -21 -47 -73 -63 -115 -76 -201 -64 -387 36 -571 42 -78 74 -119 170 -222 83 -90 102 -134 84 -191 -31 -93 -139 -126 -300 -92 -228 48 -453 168 -617 331 -186 184 -297 403 -343 673 -11 68 -23 127 -27 132 -8 14 -63 11 -239 -11 -749 -95 -1357 -245 -1446 -358 -93 -119 163 -227 751 -316 91 -14 278 -39 415 -55 138 -17 266 -35 286 -40 47 -14 115 -74 140 -124 16 -31 20 -53 17 -94 -9 -104 -66 -146 -307 -226 -264 -89 -408 -163 -462 -238 -69 -97 -11 -211 156 -304 219 -121 688 -256 1180 -339 719 -121 1715 -184 2480 -157 1066 37 2003 184 2600 406 142 53 249 112 317 173 178 164 56 301 -405 458 -93 31 -187 69 -209 85 -110 73 -117 200 -16 296 62 59 106 71 471 124 379 54 439 65 642 115 148 37 272 88 318 131 77 75 -10 156 -243 227 -360 108 -781 184 -1515 271 -22 2 -107 9 -189 15 -170 13 -181 10 -217 -62 -68 -133 -92 -289 -66 -415 32 -149 90 -257 209 -391 93 -104 116 -155 99 -212 -33 -109 -159 -135 -368 -74 -397 115 -730 440 -848 829 -31 101 -55 240 -55 315 0 41 -5 61 -16 71 -13 11 -78 14 -303 16 -157 1 -299 -2 -315 -7z"/>
                  <path d="M8013 3525 c-56 -24 -70 -79 -29 -120 13 -13 55 -33 97 -45 319 -92 476 -157 602 -250 96 -71 154 -159 156 -235 1 -43 -41 -126 -89 -178 -114 -124 -374 -255 -700 -352 -776 -230 -2136 -374 -3190 -336 -755 27 -1357 85 -1840 176 -41 8 -127 24 -190 35 -718 134 -1228 359 -1306 577 -34 98 -1 188 103 282 111 100 270 173 545 251 190 54 218 70 218 126 0 49 -37 74 -111 74 -129 0 -555 -97 -819 -187 -455 -154 -732 -338 -834 -553 -29 -60 -31 -73 -31 -171 0 -106 0 -107 45 -195 36 -71 63 -107 135 -179 113 -114 232 -193 450 -300 331 -163 769 -299 1350 -420 556 -115 1082 -181 1825 -227 277 -17 1311 -17 1570 0 596 40 908 72 1354 143 750 118 1386 294 1801 499 203 100 326 182 440 292 259 249 269 494 30 728 -245 241 -813 467 -1419 565 -115 18 -122 18 -163 0z"/>
                </g>
              </svg>
            </div>
            <h3>Termales más grandes</h3>
            <p>Acceso a Baldi Hot Springs, el complejo termal más grande del mundo con 25 piscinas calentadas por el Volcán Arenal.</p>
          </div>
        </div>
      </div>
    </section>

    
    <section class="baldi-section baldi-includes-section" id="detalles">
      <div class="baldi-container">
        <p class="baldi-eyebrow">Paquete completo</p>
        <h2 class="baldi-section-title">¿Qué incluye tu paquete?</h2>

        <div class="baldi-feat-grid">
          <div class="baldi-feat-card">
            <div class="baldi-feat-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
            </div>
            <h3>Hospedaje de Lujo</h3>
            <p>1 noche en Downtown La Fortuna Boutique Hotel. Piscina, WiFi y parqueo privado gratuito incluidos.</p>
          </div>
          <div class="baldi-feat-card baldi-feat-card--highlight">
            <div class="baldi-feat-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
            </div>
            <h3>Alimentación completa</h3>
            <p>Desayuno a la carta + bebida de bienvenida + almuerzo y cena buffet en Baldi + cocteles 2×1 de 12–5 pm.</p>
          </div>
          <div class="baldi-feat-card">
            <div class="baldi-feat-icon">
              <svg width="30" height="30" viewBox="0 0 1024 1024" fill="currentColor" aria-hidden="true">
                <g transform="translate(0,1024) scale(0.1,-0.1)" fill="currentColor" stroke="none">
                  <path d="M5381 8944 c-46 -8 -123 -27 -172 -44 -473 -158 -822 -565 -935 -1090 -26 -120 -26 -410 0 -530 35 -164 101 -322 194 -465 62 -97 106 -150 259 -307 190 -196 258 -308 283 -465 31 -192 -43 -360 -264 -607 -262 -293 -369 -482 -423 -753 -26 -131 -24 -415 4 -543 86 -396 367 -750 738 -931 118 -57 198 -86 266 -95 56 -7 61 1 23 37 -14 13 -46 51 -71 83 -215 287 -289 649 -197 971 57 199 141 323 367 539 320 306 453 493 543 761 55 167 77 321 71 500 -11 276 -80 495 -230 723 -80 122 -139 193 -301 361 -257 267 -363 456 -402 714 -65 423 183 850 629 1087 26 14 47 28 47 32 0 35 -274 49 -429 22z"/>
                  <path d="M3640 7749 c-90 -14 -259 -72 -338 -116 -86 -48 -193 -137 -264 -221 -243 -284 -302 -687 -148 -1019 55 -119 98 -178 227 -315 169 -179 211 -251 228 -389 8 -64 -13 -166 -49 -237 -34 -67 -100 -153 -194 -255 -151 -163 -230 -300 -274 -473 -31 -123 -31 -380 0 -496 96 -357 375 -650 729 -766 71 -24 173 -38 173 -25 0 5 -25 33 -56 63 -117 115 -217 299 -250 461 -24 120 -16 278 21 379 47 128 88 183 295 395 249 254 331 374 394 573 139 442 16 896 -338 1247 -188 186 -241 263 -276 400 -37 146 -25 255 47 405 40 82 58 107 137 185 55 54 117 104 155 125 36 19 66 41 69 47 10 32 -164 51 -288 32z"/>
                  <path d="M7103 7746 c-633 -120 -990 -786 -723 -1345 55 -115 115 -196 241 -327 176 -182 227 -285 217 -436 -10 -136 -65 -237 -219 -404 -125 -134 -183 -213 -235 -319 -64 -132 -85 -223 -91 -390 -5 -125 -2 -152 20 -253 79 -348 324 -634 670 -781 88 -38 220 -71 233 -58 3 3 -27 44 -68 90 -84 97 -126 163 -173 274 -102 237 -83 486 52 690 21 32 119 142 219 244 196 201 284 319 347 464 158 359 113 789 -116 1132 -28 43 -119 148 -202 233 -83 85 -165 176 -183 202 -138 201 -147 429 -25 638 55 93 171 208 271 265 45 26 82 51 82 55 0 31 -202 48 -317 26z"/>
                  <path d="M5486 4540 c-40 -13 -72 -44 -121 -120 -159 -243 -192 -578 -85 -842 44 -107 105 -207 187 -304 42 -49 84 -102 94 -119 28 -44 25 -107 -6 -144 -37 -44 -82 -55 -194 -48 -345 21 -741 269 -966 607 -177 264 -265 540 -265 828 0 156 14 148 -231 136 l-182 -9 -33 -39 c-19 -21 -47 -73 -63 -115 -76 -201 -64 -387 36 -571 42 -78 74 -119 170 -222 83 -90 102 -134 84 -191 -31 -93 -139 -126 -300 -92 -228 48 -453 168 -617 331 -186 184 -297 403 -343 673 -11 68 -23 127 -27 132 -8 14 -63 11 -239 -11 -749 -95 -1357 -245 -1446 -358 -93 -119 163 -227 751 -316 91 -14 278 -39 415 -55 138 -17 266 -35 286 -40 47 -14 115 -74 140 -124 16 -31 20 -53 17 -94 -9 -104 -66 -146 -307 -226 -264 -89 -408 -163 -462 -238 -69 -97 -11 -211 156 -304 219 -121 688 -256 1180 -339 719 -121 1715 -184 2480 -157 1066 37 2003 184 2600 406 142 53 249 112 317 173 178 164 56 301 -405 458 -93 31 -187 69 -209 85 -110 73 -117 200 -16 296 62 59 106 71 471 124 379 54 439 65 642 115 148 37 272 88 318 131 77 75 -10 156 -243 227 -360 108 -781 184 -1515 271 -22 2 -107 9 -189 15 -170 13 -181 10 -217 -62 -68 -133 -92 -289 -66 -415 32 -149 90 -257 209 -391 93 -104 116 -155 99 -212 -33 -109 -159 -135 -368 -74 -397 115 -730 440 -848 829 -31 101 -55 240 -55 315 0 41 -5 61 -16 71 -13 11 -78 14 -303 16 -157 1 -299 -2 -315 -7z"/>
                  <path d="M8013 3525 c-56 -24 -70 -79 -29 -120 13 -13 55 -33 97 -45 319 -92 476 -157 602 -250 96 -71 154 -159 156 -235 1 -43 -41 -126 -89 -178 -114 -124 -374 -255 -700 -352 -776 -230 -2136 -374 -3190 -336 -755 27 -1357 85 -1840 176 -41 8 -127 24 -190 35 -718 134 -1228 359 -1306 577 -34 98 -1 188 103 282 111 100 270 173 545 251 190 54 218 70 218 126 0 49 -37 74 -111 74 -129 0 -555 -97 -819 -187 -455 -154 -732 -338 -834 -553 -29 -60 -31 -73 -31 -171 0 -106 0 -107 45 -195 36 -71 63 -107 135 -179 113 -114 232 -193 450 -300 331 -163 769 -299 1350 -420 556 -115 1082 -181 1825 -227 277 -17 1311 -17 1570 0 596 40 908 72 1354 143 750 118 1386 294 1801 499 203 100 326 182 440 292 259 249 269 494 30 728 -245 241 -813 467 -1419 565 -115 18 -122 18 -163 0z"/>
                </g>
              </svg>
            </div>
            <h3>Aguas Termales Baldi</h3>
            <p>Pase de día completo (10AM – 10PM): 25 piscinas termales, toboganes, sauna natural y jardín termal.</p>
          </div>
        </div>

        <div class="baldi-checklist-wrap">
          <p class="baldi-checklist-title">Todo lo que está incluido</p>
          <ul class="baldi-checklist">
            {includes.map(item => (
              <li set:html={item}></li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    
    <section class="baldi-section baldi-pricing-section">
      <div class="baldi-container baldi-container--narrow">
        <p class="baldi-eyebrow">Tarifas</p>
        <h2 class="baldi-section-title">Precios para nacionales</h2>
        <div class="baldi-pricing-grid">
          {pricing.map(tier => (
            <div class={`baldi-price-card${tier.highlight ? ' baldi-price-card--highlight' : ''}`}>
              <p class="baldi-price-label">{tier.label}</p>
              <p class="baldi-price-sub">{tier.sub}</p>
              <p class="baldi-price-amount">{tier.price}</p>
            </div>
          ))}
        </div>
        <p class="baldi-pricing-note">
          ✨ Precios en colones incluyen impuestos (i.i). Válido del 10 de abril al 30 de junio de 2026.
        </p>
      </div>
    </section>

    
    <section class="baldi-section baldi-rooms-section">
      <div class="baldi-container">
        <p class="baldi-eyebrow">Nuestras habitaciones</p>
        <h2 class="baldi-section-title">Una experiencia de hospedaje en el centro de La Fortuna</h2>
        <p class="baldi-section-sub">La habitación se asigna según disponibilidad y cantidad de personas en la reserva.</p>
        <div class="baldi-rooms-grid">
          {rooms.map(room => (
            <div class="baldi-room-card">
              <div class="baldi-room-img-wrap">
                <img src={room.img} alt={room.name} loading="lazy" decoding="async" />
                <span class="baldi-room-tag">{room.tag}</span>
              </div>
              <div class="baldi-room-body">
                <p class="baldi-room-name">{room.name}</p>
                <p class="baldi-room-note">Consultar disponibilidad</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    
    <section class="baldi-section baldi-exp-section">
      <div class="baldi-container">
        <p class="baldi-eyebrow">La experiencia Baldi</p>
        <h2 class="baldi-section-title">Sumérgete en las termales</h2>
        <div class="baldi-exp-grid">
          <div class="baldi-exp-img-wrap">
            <img
              src="https://i.ibb.co/0R16Yc59/baldi1.png"
              alt="Aguas termales Baldi Hot Springs La Fortuna"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="baldi-exp-text">
