---
import logoBlancoDowntown from '../assets/logoBlancoDowntown.png';
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Un escape para relajarte desde ¢135.000 por pareja. Hospedaje + Desayunos + Termales + Cena. La Fortuna Downtown Boutique Hotel." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&family=Manrope:wght@400;600;700&display=swap" rel="stylesheet" />
  <title>Un Escape para Relajarte | La Fortuna Downtown</title>
</head>

<body>

  <section class="ep-hero">

    <!-- Fondo -->
    <div
      class="ep-bg"
      style="background-image:url('/images/_P9A3695-Mejorado-NR.jpg')"
      aria-hidden="true"
    ></div>
    <div class="ep-overlay" aria-hidden="true"></div>

    <!-- Contenido -->
    <div class="ep-content">

      <!-- Logo -->
      <a href="/" class="ep-logo-link" aria-label="La Fortuna Downtown – Inicio">
        <img
          src={logoBlancoDowntown.src}
          alt="Downtown La Fortuna Boutique Hotel"
          class="ep-logo"
          width="180"
          height="72"
        />
      </a>

      <!-- Hero copy -->
      <div class="ep-copy">
        <h1 class="ep-title">Un escape<br/>para relajarte</h1>
        <p class="ep-desde">desde:</p>
        <p class="ep-price">¢135.000</p>
        <p class="ep-price-sub">por pareja en ocupación doble</p>
      </div>

      <!-- Incluye badge -->
      <div class="ep-includes">
        <span class="ep-includes-label">Incluye:</span>
        <span class="ep-includes-badge">
          Hospedaje + Desayunos + Termales + Cena
        </span>
      </div>

      <!-- CTA principal -->
      <a
        href="https://wa.me/50685274677?text=Hola!%20Me%20interesa%20la%20promoci%C3%B3n%20de%20Ecotermales%20%C2%A2135.000"
        class="ep-cta"
        target="_blank"
        rel="noopener noreferrer"
      >
        Reservar Ahora
      </a>

      <!-- Contactos -->
      <div class="ep-contacts">
        <a href="tel:+50640002027" class="ep-contact">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          +506 4000-2027
        </a>
        <a
          href="https://wa.me/50685274677"
          class="ep-contact"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          +506 8527-4677
        </a>
      </div>

      <!-- Fine print -->
      <p class="ep-finepri">
        *Promoción válida del 1 de julio al 30 de agosto*<br/>
        *Aplican restricciones*
      </p>

    </div>
  </section>

</body>
</html>

<style>
  /* ── Reset mínimo ───────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; }

  body {
    margin: 0;
    padding: 0;
    font-family: 'Manrope', sans-serif;
    background: #0a180d;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Hero ───────────────────────────────────────────────── */
  .ep-hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* ── Fondo ──────────────────────────────────────────────── */
  .ep-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 30%;
    background-repeat: no-repeat;
    transform: scale(1.04);
    will-change: transform;
  }

  .ep-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 50% 30%, rgba(4, 14, 7, 0.2) 0%, rgba(4, 14, 7, 0) 50%),
      linear-gradient(to bottom,
        rgba(4, 14, 7, 0.55) 0%,
        rgba(4, 14, 7, 0.45) 40%,
        rgba(4, 14, 7, 0.65) 100%
      );
  }

  /* ── Contenido ──────────────────────────────────────────── */
  .ep-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    color: #fff;
    padding: clamp(2rem, 6vw, 3.5rem) clamp(1.2rem, 5vw, 3rem);
    width: 100%;
    max-width: 680px;
    gap: 0;
  }

  /* ── Logo ───────────────────────────────────────────────── */
  .ep-logo-link {
    display: inline-block;
    margin-bottom: clamp(1.6rem, 4vw, 3rem);
  }

  .ep-logo {
    width: clamp(130px, 22vw, 190px);
    height: auto;
    display: block;
    filter: drop-shadow(0 2px 12px rgba(0, 0, 0, 0.4));
  }

  /* ── Copy ───────────────────────────────────────────────── */
  .ep-copy {
    margin-bottom: clamp(1.2rem, 3vw, 2rem);
  }

  .ep-title {
    font-family: 'Dancing Script', cursive;
    font-size: clamp(3rem, 10vw, 6.5rem);
    font-weight: 700;
    line-height: 1.02;
    color: #fff;
    margin: 0 0 clamp(0.5rem, 1.5vw, 0.9rem);
    text-shadow: 0 3px 24px rgba(0, 0, 0, 0.45);
  }

  .ep-desde {
    margin: 0 0 0.1rem;
    font-size: clamp(0.78rem, 2vw, 0.9rem);
    letter-spacing: 0.22em;
    color: rgba(255, 255, 255, 0.78);
    text-transform: lowercase;
  }

  .ep-price {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(3.6rem, 13vw, 8.5rem);
    font-weight: 700;
    line-height: 1;
    color: #fff;
    margin: 0 0 0.2rem;
    text-shadow: 0 3px 28px rgba(0, 0, 0, 0.45);
    letter-spacing: -0.02em;
  }

  .ep-price-sub {
    font-size: clamp(0.85rem, 2.2vw, 1rem);
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
  }

  /* ── Incluye ────────────────────────────────────────────── */
  .ep-includes {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: clamp(1.4rem, 3.5vw, 2.2rem);
  }

  .ep-includes-label {
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
  }

  .ep-includes-badge {
    display: inline-block;
    background: #b81c2c;
    color: #fff;
    padding: 0.55rem clamp(1rem, 3vw, 1.6rem);
    border-radius: 2rem;
    font-size: clamp(0.78rem, 2.4vw, 0.95rem);
    font-weight: 700;
    letter-spacing: 0.03em;
    box-shadow: 0 4px 18px rgba(184, 28, 44, 0.45);
  }

  /* ── CTA principal ──────────────────────────────────────── */
  .ep-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.95rem 2.6rem;
    background: #fff;
    color: #1a0a0d;
    font-family: 'Manrope', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 0.1rem;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.3);
    margin-bottom: clamp(1.2rem, 3vw, 1.8rem);
    transition: background-color 0.22s ease, transform 0.22s ease, box-shadow 0.22s ease;
  }

  .ep-cta:hover {
    background: #f0ece4;
    transform: translateY(-2px);
    box-shadow: 0 10px 32px rgba(0, 0, 0, 0.38);
  }

  /* ── Contactos ──────────────────────────────────────────── */
  .ep-contacts {
    display: flex;
    gap: clamp(0.7rem, 2vw, 1.2rem);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: clamp(1rem, 2.5vw, 1.6rem);
  }

  .ep-contact {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.2rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.32);
    border-radius: 0.2rem;
    color: #fff;
    text-decoration: none;
    font-size: clamp(0.82rem, 2.2vw, 0.92rem);
    font-weight: 600;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .ep-contact:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.58);
  }

  /* ── Fine print ─────────────────────────────────────────── */
  .ep-finepri {
    margin: 0;
    font-size: clamp(0.68rem, 1.6vw, 0.76rem);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.48);
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 480px) {
    .ep-contacts {
      flex-direction: column;
      align-items: center;
    }

    .ep-contact {
      width: min(100%, 18rem);
      justify-content: center;
    }
  }
</style>
