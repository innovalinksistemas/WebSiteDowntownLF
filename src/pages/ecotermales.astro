<!-- ════════════════════════════════════════════
     COUNTDOWN SCRIPT
═════════════════════════════════════════════ -->
<script>
  const end = new Date('2026-08-30T23:59:59-06:00').getTime();

  function pad(n: number) { return String(n).padStart(2, '0'); }

  function tick() {
    const diff = end - Date.now();
    if (diff <= 0) {
      ['cd-days','cd-hours','cd-mins','cd-secs'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.textContent = '00';
      });
      return;
    }
    const days  = Math.floor(diff / 86400000);
    const hours = Math.floor((diff % 86400000) / 3600000);
    const mins  = Math.floor((diff % 3600000) / 60000);
    const secs  = Math.floor((diff % 60000) / 1000);

    (document.getElementById('cd-days')  as HTMLElement).textContent = pad(days);
    (document.getElementById('cd-hours') as HTMLElement).textContent = pad(hours);
    (document.getElementById('cd-mins')  as HTMLElement).textContent = pad(mins);
    (document.getElementById('cd-secs')  as HTMLElement).textContent = pad(secs);
  }

  tick();
  setInterval(tick, 1000);
</script>

